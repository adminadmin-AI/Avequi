// ─── Alertas (S24) ───────────────────────────────────────────────────────────

enum AlertType {
  STOCK_MIN
  PAYABLE_DUE
  PRODUCTION_LATE
  NFE_REJECTED
  MRP_RUN_DONE
  FOCUS_NFE_DOWN
  QC_INSPECTION_FAILED
  MAINTENANCE_DUE
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model Alert {
  id          String        @id @default(cuid())
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id])
  type        AlertType
  severity    AlertSeverity @default(WARNING)
  title       String
  body        String
  entityId    String?
  entityType  String?
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())

  @@index([companyId, resolvedAt])
  @@index([type])
  @@map("gdr_alerts")
}

// ─── Qualidade (S25) ─────────────────────────────────────────────────────────

enum InspectionType {
  RECEIVING
  IN_PROCESS
  FINAL
}

enum InspectionStatus {
  PENDING
  IN_PROGRESS
  PASSED
  FAILED
  ON_HOLD
}

enum NcrStatus {
  OPEN
  UNDER_ANALYSIS
  CORRECTIVE_ACTION
  CLOSED
  CANCELLED
}

enum NcrSeverity {
  MINOR
  MAJOR
  CRITICAL
}

model Inspection {
  id                String           @id @default(cuid())
  companyId         String
  company           Company          @relation(fields: [companyId], references: [id])
  type              InspectionType
  status            InspectionStatus @default(PENDING)
  goodsReceiptId    String?
  goodsReceipt      GoodsReceipt?    @relation(fields: [goodsReceiptId], references: [id])
  productionOrderId String?
  productionOrder   ProductionOrder? @relation(fields: [productionOrderId], references: [id])
  notes             String?
  inspectedById     String?
  inspectedBy       User?            @relation("InspectionInspectedBy", fields: [inspectedById], references: [id])
  startedAt         DateTime?
  finishedAt        DateTime?
  nonConformances   NonConformance[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([companyId, status])
  @@index([goodsReceiptId])
  @@index([productionOrderId])
  @@map("gdr_inspections")
}

model NonConformance {
  id               String      @id @default(cuid())
  companyId        String
  company          Company     @relation(fields: [companyId], references: [id])
  inspectionId     String?
  inspection       Inspection? @relation(fields: [inspectionId], references: [id])
  productId        String?
  product          Product?    @relation("NcrProduct", fields: [productId], references: [id])
  supplierId       String?
  supplier         Supplier?   @relation(fields: [supplierId], references: [id])
  title            String
  description      String
  severity         NcrSeverity @default(MAJOR)
  status           NcrStatus   @default(OPEN)
  rootCause        String?
  correctiveAction String?
  responsibleId    String?
  responsible      User?       @relation("NcrResponsible", fields: [responsibleId], references: [id])
  dueDate          DateTime?
  closedAt         DateTime?
  closedById       String?
  closedBy         User?       @relation("NcrClosedBy", fields: [closedById], references: [id])
  createdById      String?
  createdBy        User?       @relation("NcrCreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([companyId, status])
  @@index([supplierId])
  @@index([productId])
  @@map("gdr_non_conformances")
}

// ─── Rastreabilidade por Número de Série/Chassi (S27A) ───────────────────────

enum SerialStatus {
  IN_PRODUCTION
  IN_STOCK
  SOLD
  TRANSFERRED
  SCRAPPED
}

model SerialNumber {
  id                 String           @id @default(dbgenerated("gen_random_uuid()"))
  companyId          String           @map("company_id")
  company            Company          @relation(fields: [companyId], references: [id])
  productId          String           @map("product_id")
  product            Product          @relation("SerialProduct", fields: [productId], references: [id])
  warehouseId        String?          @map("warehouse_id")
  warehouse          Warehouse?       @relation(fields: [warehouseId], references: [id])
  serial             String           @unique
  status             SerialStatus     @default(IN_STOCK)
  productionOrderId  String?          @map("production_order_id")
  productionOrder    ProductionOrder? @relation(fields: [productionOrderId], references: [id])
  salesOrderId       String?          @map("sales_order_id")
  salesOrder         SalesOrder?      @relation(fields: [salesOrderId], references: [id])
  producedAt         DateTime?        @map("produced_at")
  soldAt             DateTime?        @map("sold_at")
  legacyId           Int?             @map("legacy_id")
  legacyOsId         Int?             @map("legacy_os_id")
  engravingStartedAt DateTime?        @map("engraving_started_at")
  engravingDoneAt    DateTime?        @map("engraving_done_at")
  engravingOperator  String?          @map("engraving_operator")
  observations       String?
  createdAt          DateTime         @default(now()) @map("created_at")

  @@index([companyId, status])
  @@index([productId, status])
  @@map("gdr_serial_number")
}

// ─── Manutenção de Equipamentos (S27B) ───────────────────────────────────────

enum EquipmentStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  SCRAPPED
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  CALIBRATION
  INSPECTION
}

enum MaintenanceOrderStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

model Equipment {
  id               String          @id @default(cuid())
  companyId        String
  company          Company         @relation(fields: [companyId], references: [id])
  code             String
  name             String
  description      String?
  location         String?
  status           EquipmentStatus @default(ACTIVE)
  acquisitionDate  DateTime?
  nextMaintenanceAt DateTime?
  maintenanceIntervalDays Int      @default(30)
  maintenanceOrders MaintenanceOrder[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([companyId, code])
  @@index([companyId, status])
  @@map("gdr_equipment")
}

model MaintenanceOrder {
  id           String                 @id @default(cuid())
  companyId    String
  company      Company                @relation(fields: [companyId], references: [id])
  equipmentId  String
  equipment    Equipment              @relation(fields: [equipmentId], references: [id])
  type         MaintenanceType        @default(PREVENTIVE)
  status       MaintenanceOrderStatus @default(OPEN)
  title        String
  description  String?
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  technicianId String?
  technician   User?                  @relation("MaintenanceTechnician", fields: [technicianId], references: [id])
  resolution   String?
  cost         Decimal?               @db.Decimal(14, 4)
  createdById  String?
  createdBy    User?                  @relation("MaintenanceCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([companyId, status])
  @@index([equipmentId])
  @@map("gdr_maintenance_orders")
}

// ─── Orçamentos / Propostas Comerciais (S28A) ─────────────────────────────────

enum QuotationStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

model Quotation {
  id           String          @id @default(cuid())
  companyId    String
  company      Company         @relation(fields: [companyId], references: [id])
  customerId   String?
  customer     Customer?       @relation(fields: [customerId], references: [id])
  warehouseId  String
  warehouse    Warehouse       @relation(fields: [warehouseId], references: [id])
  status       QuotationStatus @default(DRAFT)
  validUntil   DateTime?
  notes        String?
  discount     Decimal         @default(0) @db.Decimal(5, 2)
  items        QuotationItem[]
  salesOrder   SalesOrder?     @relation(fields: [salesOrderId], references: [id])
  salesOrderId String?         @unique
  createdById  String?
  createdBy    User?           @relation("QuotationCreatedBy", fields: [createdById], references: [id])
  sentAt       DateTime?
  approvedAt   DateTime?
  rejectedAt   DateTime?
  rejectionReason String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([companyId, status])
  @@index([customerId])
  @@map("gdr_quotations")
}

model QuotationItem {
  id           String    @id @default(cuid())
  quotationId  String
  quotation    Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId    String
  product      Product   @relation("QuotationItemProduct", fields: [productId], references: [id])
  quantity     Decimal   @db.Decimal(14, 4)
  unitPrice    Decimal   @db.Decimal(14, 4)
  discount     Decimal   @default(0) @db.Decimal(5, 2)
  unit         UnitOfMeasure @default(UN)

  @@map("gdr_quotation_items")
}

// ─── Portal do Fornecedor (S27C) ─────────────────────────────────────────────

model SupplierToken {
  id          String    @id @default(cuid())
  supplierId  String
  supplier    Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  token       String    @unique @default(cuid())
  description String?   // e.g. "Token para integração ERP cliente"
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([supplierId])
  @@map("gdr_supplier_tokens")
}

// ─── NF-e de Entrada (S28B) ──────────────────────────────────────────────────

enum InboundNfeStatus {
  PENDING
  MATCHED
  IMPORTED
  REJECTED
}

model InboundNfe {
  id              String           @id @default(cuid())
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])
  chaveNfe        String           @unique  // 44-digit key
  nfeNumber       String?
  series          String?
  supplierCnpj    String
  supplierName    String
  issueDate       DateTime?
  totalValue      Decimal?         @db.Decimal(14, 4)
  status          InboundNfeStatus @default(PENDING)
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id])
  goodsReceiptId  String?          @unique
  goodsReceipt    GoodsReceipt?    @relation(fields: [goodsReceiptId], references: [id])
  xmlContent      String           // raw XML
  parsedItems     Json             // array of { ncm, description, quantity, unitPrice, totalPrice }
  rejectReason    String?
  importedById    String?
  importedBy      User?            @relation("InboundNfeImportedBy", fields: [importedById], references: [id])
  importedAt      DateTime?
  threeWayMatches ThreeWayMatch[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([companyId, status])
  @@index([supplierCnpj])
  @@map("gdr_inbound_nfe")
}

// ─── Planejamento de Capacidade (S28C) ───────────────────────────────────────

model WorkCenter {
  id                  String   @id @default(cuid())
  companyId           String
  company             Company  @relation(fields: [companyId], references: [id])
  code                String
  name                String
  description         String?
  capacityHoursPerDay Decimal  @default(8) @db.Decimal(5, 2)
  operatorsCount      Int      @default(1)
  efficiencyPct       Decimal  @default(85) @db.Decimal(5, 2)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
  @@map("gdr_work_centers")
}

// ─── Gestão de Lotes (S28D) ──────────────────────────────────────────────────

enum BatchStatus {
  ACTIVE
  QUARANTINE
  CONSUMED
  EXPIRED
  SCRAPPED
}

enum BatchEventType {
  RECEIPT
  TRANSFER
  CONSUMPTION
  ADJUSTMENT
  QUARANTINE
  RELEASE
  EXPIRY
  SCRAP
}

model Batch {
  id                 String      @id @default(cuid())
  companyId          String
  company            Company     @relation(fields: [companyId], references: [id])
  batchNumber        String
  productId          String
  product            Product     @relation("BatchProduct", fields: [productId], references: [id])
  supplierId         String?
  supplier           Supplier?   @relation("BatchSupplier", fields: [supplierId], references: [id])
  goodsReceiptId     String?
  goodsReceipt       GoodsReceipt? @relation(fields: [goodsReceiptId], references: [id])
  status             BatchStatus @default(ACTIVE)
  initialQty         Decimal     @db.Decimal(14, 4)
  currentQty         Decimal     @db.Decimal(14, 4)
  unit               UnitOfMeasure @default(UN)
  manufacturingDate  DateTime?
  expirationDate     DateTime?
  warehouseId        String?
  warehouse          Warehouse?  @relation(fields: [warehouseId], references: [id])
  notes              String?
  events             BatchEvent[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@unique([companyId, batchNumber, productId])
  @@index([companyId, status])
  @@index([productId])
  @@index([expirationDate])
  @@map("gdr_batches")
}

model BatchEvent {
  id                  String         @id @default(cuid())
  batchId             String
  batch               Batch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  type                BatchEventType
  quantity            Decimal        @db.Decimal(14, 4)
  qtyBefore           Decimal        @db.Decimal(14, 4)
  qtyAfter            Decimal        @db.Decimal(14, 4)
  productionOrderId   String?
  productionOrder     ProductionOrder? @relation(fields: [productionOrderId], references: [id])
  warehouseFromId     String?
  warehouseTo         String?
  reference           String?
  notes               String?
  userId              String?
  user                User?          @relation("BatchEventUser", fields: [userId], references: [id])
  createdAt           DateTime       @default(now())

  @@index([batchId])
  @@index([productionOrderId])
  @@map("gdr_batch_events")
}
// ─── Categorias Financeiras ──────────────────────────────────────────────────

enum FinancialCategoryType {
  REVENUE
  EXPENSE
  TRANSFER
  GROUP
}

model FinancialCategory {
  id        String                @id @default(cuid())
  companyId String
  company   Company               @relation(fields: [companyId], references: [id])
  code      String?
  name      String
  type      FinancialCategoryType @default(EXPENSE)
  parentId  String?
  parent    FinancialCategory?    @relation("subcategories", fields: [parentId], references: [id])
  children  FinancialCategory[]   @relation("subcategories")
  dreCode   String?
  isActive  Boolean               @default(true)
  legacyId  String?

  entries     FinancialEntry[]
  payables    Payable[]
  receivables Receivable[]

  createdAt DateTime @default(now())

  @@unique([companyId, code])
  @@map("gdr_financial_categories")
}

// ─── Centro de Custo ──────────────────────────────────────────────────────────

model CostCenter {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  name      String
  code      String?
  isActive  Boolean @default(true)
  parentId  String?
  parent    CostCenter?  @relation("CostCenterHierarchy", fields: [parentId], references: [id])
  children  CostCenter[] @relation("CostCenterHierarchy")
  legacyId  String?

  payableAllocations    PayableAllocation[]
  receivableAllocations ReceivableAllocation[]
  entrySplits           EntryCostCenterSplit[]

  createdAt DateTime @default(now())

  @@index([parentId])
  @@map("gdr_cost_centers")
}

// ─── Contas a Pagar ───────────────────────────────────────────────────────────

enum PayableStatus {
  OPEN
  PAID
  CANCELLED
  OVERDUE
}

model Payable {
  id              String             @id @default(cuid())
  companyId       String
  company         Company            @relation(fields: [companyId], references: [id])
  supplierId      String?
  supplier        Supplier?          @relation(fields: [supplierId], references: [id])
  categoryId      String?
  category        FinancialCategory? @relation(fields: [categoryId], references: [id])
  bankAccountId   String?
  bankAccount     BankAccount?       @relation(fields: [bankAccountId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id])
  description     String?
  amount          Decimal            @db.Decimal(14, 4)
  dueDate         DateTime
  status          PayableStatus      @default(OPEN)
  paidAt          DateTime?
  paidAmount      Decimal?           @db.Decimal(14, 4)
  origin          String?
  legacyId        String?

  allocations    PayableAllocation[]
  paymentEntries PaymentEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([dueDate])
  @@map("gdr_payables")
}

model PayableAllocation {
  id           String     @id @default(cuid())
  payableId    String
  payable      Payable    @relation(fields: [payableId], references: [id], onDelete: Cascade)
  costCenterId String
  costCenter   CostCenter @relation(fields: [costCenterId], references: [id])
  percentage   Decimal    @db.Decimal(5, 2)

  @@map("gdr_payable_allocations")
}

model PaymentEntry {
  id        String   @id @default(cuid())
  payableId String
  payable   Payable  @relation(fields: [payableId], references: [id])
  amount    Decimal  @db.Decimal(14, 4)
  paidAt    DateTime
  origin    String?
  legacyId  String?

  createdAt DateTime @default(now())

  @@map("gdr_payment_entries")
}

// ─── Contas a Receber ─────────────────────────────────────────────────────────

enum ReceivableStatus {
  OPEN
  PAID
  CANCELLED
  OVERDUE
}

model Receivable {
  id            String             @id @default(cuid())
  companyId     String
  company       Company            @relation(fields: [companyId], references: [id])
  customerId    String?
  customer      Customer?          @relation(fields: [customerId], references: [id])
  categoryId    String?
  category      FinancialCategory? @relation(fields: [categoryId], references: [id])
  bankAccountId String?
  bankAccount   BankAccount?       @relation(fields: [bankAccountId], references: [id])
  salesOrderId  String?            @unique
  salesOrder    SalesOrder?        @relation(fields: [salesOrderId], references: [id])
  description   String?
  amount        Decimal            @db.Decimal(14, 4)
  dueDate       DateTime
  status        ReceivableStatus   @default(OPEN)
  paidAt        DateTime?
  paidAmount    Decimal?           @db.Decimal(14, 4)
  accessKey     String?
  legacyId      String?

  allocations ReceivableAllocation[]
  boletos     Boleto[]
  ddaDebits   DdaDebit[]
  pixCharges  PixCharge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([dueDate])
  @@map("gdr_receivables")
}

model ReceivableAllocation {
  id           String     @id @default(cuid())
  receivableId String
  receivable   Receivable @relation(fields: [receivableId], references: [id], onDelete: Cascade)
  costCenterId String
  costCenter   CostCenter @relation(fields: [costCenterId], references: [id])
  percentage   Decimal    @db.Decimal(5, 2)

  @@map("gdr_receivable_allocations")
}

// ─── Banking — CNAB 240 ─────────────────────────────────────────────────────

enum CnabRemessaStatus {
  PENDING
  GENERATED
  SENT
  ERROR
}

enum CnabRetornoStatus {
  PENDING
  PROCESSING
  PROCESSED
  ERROR
}

enum BoletoStatus {
  PENDING
  REGISTERED
  PAID
  CANCELLED
  OVERDUE
  WRITTEN_OFF
}

model Boleto {
  id              String       @id @default(cuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id])
  bankAccountId   String
  bankAccount     BankAccount  @relation(fields: [bankAccountId], references: [id])
  receivableId    String?
  receivable      Receivable?  @relation(fields: [receivableId], references: [id])
  nossoNumero     String
  seuNumero       String?
  amount          Decimal      @db.Decimal(14, 4)
  dueDate         DateTime
  status          BoletoStatus @default(PENDING)
  payerName       String
  payerDocument   String
  payerAddress    String?
  payerCity       String?
  payerState      String?
  payerZipCode    String?
  registeredAt    DateTime?
  paidAt          DateTime?
  paidAmount      Decimal?     @db.Decimal(14, 4)
  cancelledAt     DateTime?
  instructions    String?

  remessaItems CnabRemessaItem[]
  retornoItems CnabRetornoItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bankAccountId, nossoNumero])
  @@index([companyId, status])
  @@map("gdr_boletos")
}

model CnabRemessa {
  id            String             @id @default(cuid())
  companyId     String
  company       Company            @relation(fields: [companyId], references: [id])
  bankAccountId String
  bankAccount   BankAccount        @relation(fields: [bankAccountId], references: [id])
  fileName      String
  sequenceNumber Int
  totalBoletos  Int
  totalAmount   Decimal            @db.Decimal(14, 4)
  status        CnabRemessaStatus  @default(PENDING)
  fileContent   String?
  errorMessage  String?
  generatedAt   DateTime?
  sentAt        DateTime?

  items CnabRemessaItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("gdr_cnab_remessas")
}

model CnabRemessaItem {
  id          String       @id @default(cuid())
  remessaId   String
  remessa     CnabRemessa  @relation(fields: [remessaId], references: [id], onDelete: Cascade)
  boletoId    String
  boleto      Boleto       @relation(fields: [boletoId], references: [id])
  segmento    String
  lineNumber  Int
  lineContent String

  @@map("gdr_cnab_remessa_items")
}

model CnabRetorno {
  id            String             @id @default(cuid())
  companyId     String
  company       Company            @relation(fields: [companyId], references: [id])
  bankAccountId String
  bankAccount   BankAccount        @relation(fields: [bankAccountId], references: [id])
  fileName      String
  processedAt   DateTime?
  matchedCount  Int                @default(0)
  unmatchedCount Int               @default(0)
  totalAmount   Decimal?           @db.Decimal(14, 4)
  status        CnabRetornoStatus  @default(PENDING)
  errorMessage  String?

  items CnabRetornoItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("gdr_cnab_retornos")
}

model CnabRetornoItem {
  id            String       @id @default(cuid())
  retornoId     String
  retorno       CnabRetorno  @relation(fields: [retornoId], references: [id], onDelete: Cascade)
  boletoId      String?
  boleto        Boleto?      @relation(fields: [boletoId], references: [id])
  nossoNumero   String
  occurrence    String
  occurrenceDesc String?
  amount        Decimal?     @db.Decimal(14, 4)
  paidAmount    Decimal?     @db.Decimal(14, 4)
  paidAt        DateTime?
  matched       Boolean      @default(false)

  @@map("gdr_cnab_retorno_items")
}

model ReconciliationItem {
  id            String       @id @default(cuid())
  companyId     String
  company       Company      @relation(fields: [companyId], references: [id])
  bankAccountId String
  bankAccount   BankAccount  @relation(fields: [bankAccountId], references: [id])
  date          DateTime
  description   String
  amount        Decimal      @db.Decimal(14, 4)
  type          String
  matched       Boolean      @default(false)
  matchedToId   String?
  matchedToType String?
  importSource  String?

  createdAt DateTime @default(now())

  @@index([companyId, bankAccountId])
  @@index([date])
  @@map("gdr_reconciliation_items")
}

// ─── DDA — Débito Direto Autorizado ──────────────────────────────────────────

enum DdaConsentStatus {
  PENDING
  ACTIVE
  CANCELLED
  EXPIRED
}

model DdaMandate {
  id            String           @id @default(cuid())
  companyId     String
  company       Company          @relation(fields: [companyId], references: [id])
  customerId    String
  customer      Customer         @relation(fields: [customerId], references: [id])
  bankAccountId String
  bankAccount   BankAccount      @relation(fields: [bankAccountId], references: [id])
  consentStatus DdaConsentStatus @default(PENDING)
  maxAmount     Decimal?         @db.Decimal(14, 4)
  startDate     DateTime
  endDate       DateTime?
  cancelledAt   DateTime?
  reference     String?

  debits DdaDebit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@map("gdr_dda_mandates")
}

model DdaDebit {
  id           String      @id @default(cuid())
  mandateId    String
  mandate      DdaMandate  @relation(fields: [mandateId], references: [id])
  amount       Decimal     @db.Decimal(14, 4)
  debitDate    DateTime
  status       String      @default("PENDING") // PENDING, PROCESSED, FAILED, REVERSED
  processedAt  DateTime?
  failReason   String?
  receivableId String?
  receivable   Receivable? @relation(fields: [receivableId], references: [id])

  createdAt DateTime @default(now())

  @@index([mandateId])
  @@map("gdr_dda_debits")
}

// ─── S40: Limite de Crédito ───────────────────────────────────────────────────

enum CreditLimitStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

model CreditLimit {
  id         String            @id @default(cuid())
  companyId  String
  company    Company           @relation(fields: [companyId], references: [id])
  customerId String
  customer   Customer          @relation(fields: [customerId], references: [id])
  maxAmount  Decimal           @db.Decimal(14, 4)
  usedAmount Decimal           @default(0) @db.Decimal(14, 4)
  status     CreditLimitStatus @default(ACTIVE)
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, customerId])
  @@map("gdr_credit_limits")
}

// ─── S40: Cobrança Pix ────────────────────────────────────────────────────────

model PixCharge {
  id            String      @id @default(cuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id])
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  receivableId  String?
  receivable    Receivable? @relation(fields: [receivableId], references: [id])
  txId          String      @unique
  amount        Decimal     @db.Decimal(14, 4)
  description   String?
  pixKey        String
  qrCode        String      // EMV payload
  status        String      @default("ACTIVE") // ACTIVE, PAID, CANCELLED, EXPIRED
  expiresAt     DateTime?
  paidAt        DateTime?
  paidAmount    Decimal?    @db.Decimal(14, 4)
  e2eId         String?     // endToEndId from Pix

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([txId])
  @@map("gdr_pix_charges")
}

// ─── S41: Anti-fraude ─────────────────────────────────────────────────────────

model FraudRule {
  id              String       @id @default(cuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id])
  bankAccountId   String?
  bankAccount     BankAccount? @relation(fields: [bankAccountId], references: [id])
  transactionType String       // BOLETO, PIX, TRANSFER, PAYMENT
  maxAmount       Decimal      @db.Decimal(14, 4)
  isActive        Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, bankAccountId, transactionType])
  @@map("gdr_fraud_rules")
}

model FraudAlert {
  id            String      @id @default(cuid())
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id])
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  flagType      String      // UNUSUAL_HOUR, HIGH_VALUE, DUPLICATE, RATE_LIMIT, WHITELIST_EXCEEDED
  severity      String      // LOW, MEDIUM, HIGH
  amount        Decimal     @db.Decimal(14, 4)
  message       String
  resolved      Boolean     @default(false)
  resolvedAt    DateTime?
  resolvedBy    String?

  createdAt DateTime @default(now())

  @@index([companyId, resolved])
  @@map("gdr_fraud_alerts")
}

// ─── BPM — Business Process Management ──────────────────────────────────────

enum WorkflowStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum WorkflowInstanceStatus {
  RUNNING
  COMPLETED
  CANCELLED
  ERROR
  WAITING_APPROVAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model Workflow {
  id          String         @id @default(cuid())
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id])
  name        String
  description String?
  entityType  String
  status      WorkflowStatus @default(ACTIVE)
  triggerEvent String?

  versions  WorkflowVersion[]
  instances WorkflowInstance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@index([companyId, entityType])
  @@map("gdr_workflows")
}

model WorkflowVersion {
  id         String    @id @default(cuid())
  workflowId String
  workflow   Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  version    Int
  definition Json
  isActive   Boolean   @default(false)
  publishedAt DateTime?

  createdAt DateTime @default(now())

  @@unique([workflowId, version])
  @@map("gdr_workflow_versions")
}

model WorkflowInstance {
  id            String                 @id @default(cuid())
  companyId     String
  company       Company                @relation(fields: [companyId], references: [id])
  workflowId    String
  workflow      Workflow               @relation(fields: [workflowId], references: [id])
  entityType    String
  entityId      String
  status        WorkflowInstanceStatus @default(RUNNING)
  currentNodeId String?
  variables     Json?
  startedAt     DateTime               @default(now())
  completedAt   DateTime?
  errorMessage  String?

  approvals ApprovalRequest[]
  history   WorkflowHistory[]
  actions   WorkflowAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, entityType, entityId])
  @@index([status])
  @@map("gdr_workflow_instances")
}

model WorkflowHistory {
  id          String           @id @default(cuid())
  instanceId  String
  instance    WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  fromNodeId  String?
  toNodeId    String
  action      String
  metadata    Json?
  performedBy String?

  createdAt DateTime @default(now())

  @@map("gdr_workflow_history")
}

model ApprovalMatrix {
  id                String   @id @default(cuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id])
  entityType        String
  conditionField    String?
  conditionOp       String?
  conditionValue    String?
  level             Int      @default(1)
  requiredApprovals Int      @default(1)
  approverRoles     String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, entityType])
  @@map("gdr_approval_matrices")
}

model ApprovalRequest {
  id           String           @id @default(cuid())
  instanceId   String
  instance     WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  level        Int
  approverRole String
  approverId   String?
  status       ApprovalStatus   @default(PENDING)
  comments     String?
  respondedAt  DateTime?

  createdAt DateTime @default(now())

  @@index([instanceId, level])
  @@map("gdr_approval_requests")
}

model SlaDefinition {
  id               String  @id @default(cuid())
  companyId        String
  company          Company @relation(fields: [companyId], references: [id])
  entityType       String
  statusFrom       String
  statusTo         String
  maxDurationHours Int
  escalateToRole   String?
  isActive         Boolean @default(true)

  breaches SlaBreach[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, entityType, statusFrom, statusTo])
  @@map("gdr_sla_definitions")
}

model SlaBreach {
  id              String        @id @default(cuid())
  slaDefinitionId String
  slaDefinition   SlaDefinition @relation(fields: [slaDefinitionId], references: [id])
  entityType      String
  entityId        String
  expectedAt      DateTime
  breachedAt      DateTime
  resolved        Boolean       @default(false)
  resolvedAt      DateTime?

  createdAt DateTime @default(now())

  @@index([slaDefinitionId])
  @@map("gdr_sla_breaches")
}

// ─── S35: BPM Rule Engine + Actions ──────────────────────────────────────────

enum WorkflowActionStatus {
  PENDING
  EXECUTING
  COMPLETED
  FAILED
}

model WorkflowAction {
  id         String               @id @default(cuid())
  instanceId String
  instance   WorkflowInstance     @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  nodeId     String
  actionType String
  config     Json?
  status     WorkflowActionStatus @default(PENDING)
  result     Json?
  error      String?
  executedAt DateTime?

  createdAt DateTime @default(now())

  @@index([instanceId])
  @@map("gdr_workflow_actions")
}

model EmailTemplate {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  name      String
  subject   String
  bodyHtml  String
  bodyText  String?
  variables String[]
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@map("gdr_email_templates")
}

model Notification {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])
  userId     String?
  role       String?
  title      String
  message    String
  type       String   @default("INFO")
  entityType String?
  entityId   String?
  read       Boolean  @default(false)
  readAt     DateTime?

  createdAt DateTime @default(now())

  @@index([companyId, userId, read])
  @@map("gdr_notifications")
}

// ─── S36: BPM Task Management + SLA Tracker ──────────────────────────────────

enum TaskAssignmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  OVERDUE
}

model TaskAssignment {
  id          String               @id @default(cuid())
  companyId   String
  company     Company              @relation(fields: [companyId], references: [id])
  userId      String?
  role        String?
  entityType  String
  entityId    String
  action      String
  title       String
  description String?
  dueDate     DateTime?
  priority    String               @default("NORMAL")
  status      TaskAssignmentStatus @default(PENDING)
  completedAt DateTime?
  completedBy String?
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, userId, status])
  @@index([companyId, role, status])
  @@index([dueDate])
  @@map("gdr_task_assignments")
}

// ─── S37: BPM Visual Editor — Workflow Templates ──────────────────────────────

model WorkflowTemplate {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  entityType  String
  category    String? // APPROVAL, PRODUCTION, SALES, ONBOARDING
  definition  Json    // { nodes: [], edges: [] }
  isBuiltIn   Boolean @default(false)

  createdAt DateTime @default(now())

  @@map("gdr_workflow_templates")
}

// ─── BI — Fact Tables ────────────────────────────────────────────────────────

model FactSalesDaily {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])
  period     String   // YYYY-MM-DD
  productId  String?
  customerId String?
  categoryId String?
  region     String?
  state      String?
  city       String?
  revenue    Decimal  @db.Decimal(14, 4)
  quantity   Decimal  @db.Decimal(14, 4)
  orderCount Int      @default(0)
  avgTicket  Decimal? @db.Decimal(14, 4)

  createdAt DateTime @default(now())

  @@unique([companyId, period, productId, customerId])
  @@index([companyId, period])
  @@index([productId])
  @@index([customerId])
  @@map("gdr_fact_sales_daily")
}

model FactInventoryDaily {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id])
  period      String  // YYYY-MM-DD
  productId   String
  warehouseId String
  categoryId  String?
  quantity    Decimal @db.Decimal(14, 4)
  value       Decimal @db.Decimal(14, 4)
  avgCost     Decimal? @db.Decimal(14, 4)

  createdAt DateTime @default(now())

  @@unique([companyId, period, productId, warehouseId])
  @@index([companyId, period])
  @@index([warehouseId])
  @@map("gdr_fact_inventory_daily")
}

model FactProductionDaily {
  id           String  @id @default(cuid())
  companyId    String
  company      Company @relation(fields: [companyId], references: [id])
  period       String  // YYYY-MM-DD
  productId    String
  workCenterId String?
  quantity     Decimal @db.Decimal(14, 4)
  materialCost Decimal @db.Decimal(14, 4)
  laborCost    Decimal @db.Decimal(14, 4)
  totalCost    Decimal @db.Decimal(14, 4)
  orderCount   Int     @default(0)

  createdAt DateTime @default(now())

  @@unique([companyId, period, productId, workCenterId])
  @@index([companyId, period])
  @@map("gdr_fact_production_daily")
}

model FactFinancialDaily {
  id            String  @id @default(cuid())
  companyId     String
  company       Company @relation(fields: [companyId], references: [id])
  period        String  // YYYY-MM-DD
  bankAccountId String?
  categoryId    String?
  type          String  // REVENUE, EXPENSE
  amount        Decimal @db.Decimal(14, 4)
  count         Int     @default(0)

  createdAt DateTime @default(now())

  @@unique([companyId, period, bankAccountId, categoryId, type])
  @@index([companyId, period])
  @@map("gdr_fact_financial_daily")
}

// ─── BI — Dashboards ─────────────────────────────────────────────────────────

model Dashboard {
  id          String  @id @default(cuid())
  companyId   String
  company     Company @relation(fields: [companyId], references: [id])
  userId      String
  name        String
  description String?
  layout      Json?   // grid layout config (react-grid-layout format)
  isDefault   Boolean @default(false)
  isShared    Boolean @default(false)

  widgets DashboardWidget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, userId])
  @@map("gdr_dashboards")
}

enum WidgetType {
  KPI_CARD
  LINE_CHART
  BAR_CHART
  PIE_CHART
  TABLE
  GAUGE
}

model DashboardWidget {
  id              String     @id @default(cuid())
  dashboardId     String
  dashboard       Dashboard  @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  type            WidgetType
  title           String
  config          Json       // { dataSource, metric, filters, ... }
  position        Json       // { x, y, w, h } for grid layout
  refreshInterval Int?       // seconds, null = manual

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gdr_dashboard_widgets")
}

// ─── BI — Alert Rules ────────────────────────────────────────────────────────

enum AlertRuleOperator {
  GT
  GTE
  LT
  LTE
  ANOMALY
}

model AlertRule {
  id          String            @id @default(cuid())
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id])
  name        String
  metric      String            // revenue, quantity, cost, etc.
  dataSource  String            // sales, inventory, production, financial
  operator    AlertRuleOperator
  threshold   Decimal?          @db.Decimal(14, 4)
  windowDays  Int               @default(30)
  isActive    Boolean           @default(true)
  notifyRoles String[]

  triggers AlertTrigger[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, isActive])
  @@map("gdr_alert_rules")
}

model AlertTrigger {
  id             String    @id @default(cuid())
  alertRuleId    String
  alertRule      AlertRule @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id])
  value          Decimal   @db.Decimal(14, 4)
  threshold      Decimal?  @db.Decimal(14, 4)
  message        String
  acknowledged   Boolean   @default(false)
  acknowledgedAt DateTime?
  acknowledgedBy String?

  createdAt DateTime @default(now())

  @@index([alertRuleId])
  @@index([companyId])
  @@map("gdr_alert_triggers")
}

// ─── BI — Semantic Layer ─────────────────────────────────────────────────────

model MetricDefinition {
  id          String   @id @default(cuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  name        String
  displayName String
  description String?
  dataSource  String
  expression  String
  unit        String?
  format      String?
  isBuiltIn   Boolean @default(false)
  category    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, name])
  @@map("gdr_metric_definitions")
}

model DimensionDefinition {
  id          String   @id @default(cuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  name        String
  displayName String
  description String?
  dataSource  String
  field       String
  hierarchy   String?
  isBuiltIn   Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([companyId, name])
  @@map("gdr_dimension_definitions")
}

model ReportSchedule {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  dashboardId String?
  format      String   @default("PDF")
  cronExpr    String
  recipients  String[]
  isActive    Boolean  @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?

  runs ReportRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, isActive])
  @@map("gdr_report_schedules")
}

model ReportRun {
  id          String         @id @default(cuid())
  scheduleId  String
  schedule    ReportSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  status      String         @default("PENDING")
  format      String
  fileSize    Int?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())

  @@index([scheduleId])
  @@map("gdr_report_runs")
}

model AnalyticsQueryLog {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  userId    String
  endpoint  String
  params    Json?
  duration  Int
  cached    Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([companyId, createdAt])
  @@map("gdr_analytics_query_logs")
}
