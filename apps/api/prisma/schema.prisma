generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Empresa / Tenant ─────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String
  cnpj      String   @unique
  type      CompanyType @default(MATRIZ)
  parentId  String?
  parent    Company?  @relation("branches", fields: [parentId], references: [id])
  branches  Company[] @relation("branches")
  users     User[]
  auditLogs AuditLog[]
  products  Product[]
  suppliers Supplier[]
  customers Customer[]
  bomVersions    BomVersion[]
  routingSteps   RoutingStep[]
  warehouses       Warehouse[]
  stockBalances    StockBalance[]
  stockMovements   StockMovement[]
  purchaseOrders   PurchaseOrder[]
  goodsReceipts    GoodsReceipt[]
  salesOrders      SalesOrder[]
  fiscalDocuments  FiscalDocument[]
  financialEntries     FinancialEntry[]
  bankAccounts         BankAccount[]
  storeTransfers       StoreTransfer[]
  demandForecasts      DemandForecast[]
  purchaseRequests     PurchaseRequest[]
  supplierPriceHistory SupplierPriceHistory[]
  systemParameters     SystemParameter[]
  mrpRuns              MrpRun[]
  productionOrders     ProductionOrder[]
  locations        Location[]
  receivingOrders  ReceivingOrder[]
  putawayTasks     PutawayTask[]
  pickingOrders    PickingOrder[]
  pickTasks        PickTask[]
  inventoryCounts  InventoryCount[]
  inventoryItems   InventoryCountItem[]
  alerts           Alert[]
  inspections      Inspection[]
  nonConformances  NonConformance[]
  serialNumbers    SerialNumber[]
  equipment        Equipment[]
  maintenanceOrders MaintenanceOrder[]
  quotations       Quotation[]
  inboundNfes      InboundNfe[]
  workCenters      WorkCenter[]
  batches          Batch[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gdr_companies")
}

enum CompanyType {
  MATRIZ
  FILIAL
}

// ─── Usuário ──────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          UserRole @default(READER)
  isActive      Boolean  @default(true)
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  stockMovements            StockMovement[]
  createdPurchaseOrders     PurchaseOrder[] @relation("POCreatedBy")
  approvedPurchaseOrders    PurchaseOrder[] @relation("POApprovedBy")
  goodsReceipts             GoodsReceipt[]  @relation("GRReceivedBy")
  createdSalesOrders        SalesOrder[]    @relation("SOCreatedBy")
  requestedTransfers        StoreTransfer[] @relation("TransferRequestedBy")
  dispatchedTransfers       StoreTransfer[] @relation("TransferDispatchedBy")
  receivedTransfers         StoreTransfer[] @relation("TransferReceivedBy")
  demandForecasts           DemandForecast[]    @relation("DemandCreatedBy")
  purchaseRequests          PurchaseRequest[]   @relation("PRRequestedBy")
  triggeredMrpRuns          MrpRun[]            @relation("MrpTriggeredBy")
  createdProductionOrders   ProductionOrder[]   @relation("POProdCreatedBy")
  productionLogs            ProductionLog[]     @relation("ProductionLogUser")
  putawayConfirmations      PutawayTask[]       @relation("PutawayConfirmedBy")
  pickConfirmations         PickTask[]          @relation("PickConfirmedBy")
  inventoryCountsCreated    InventoryCount[]    @relation("InventoryCreatedBy")
  inventoryCountsReconciled InventoryCount[]    @relation("InventoryReconciledBy")
  inventoryItemsCounted     InventoryCountItem[] @relation("InventoryItemCountedBy")
  inspectionsLed            Inspection[]        @relation("InspectionInspectedBy")
  ncrResponsibilities       NonConformance[]    @relation("NcrResponsible")
  ncrsClosed                NonConformance[]    @relation("NcrClosedBy")
  ncrsCreated               NonConformance[]    @relation("NcrCreatedBy")
  maintenanceTasks          MaintenanceOrder[]  @relation("MaintenanceTechnician")
  maintenanceOrdersCreated  MaintenanceOrder[]  @relation("MaintenanceCreatedBy")
  quotationsCreated         Quotation[]         @relation("QuotationCreatedBy")
  inboundNfesImported       InboundNfe[]        @relation("InboundNfeImportedBy")
  batchEvents               BatchEvent[]        @relation("BatchEventUser")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("gdr_users")
}

enum UserRole {
  SUPER_ADMIN
  DIRECTOR
  MANAGER
  COMMERCIAL
  PRODUCTION
  QUALITY
  WAREHOUSE
  FINANCIAL
  STORE
  READER
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@map("gdr_refresh_tokens")
}

// ─── Auditoria ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  entity    String
  action    String
  payload   Json?
  createdAt DateTime @default(now())

  @@map("gdr_audit_logs")
}

// ─── Produto ──────────────────────────────────────────────────────────────────

enum ProductType {
  RAW_MATERIAL
  SEMI_FINISHED
  FINISHED_GOOD
  CONSUMABLE
  SERVICE
  COMPONENT
}

enum UnitOfMeasure {
  UN
  KG
  G
  M
  M2
  M3
  L
  PC
  CX
  PR
}

model Product {
  id          String         @id @default(cuid())
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id])
  sku         String
  name        String
  description String?
  type        ProductType
  unit        UnitOfMeasure  @default(UN)
  ncm         String?
  costPrice   Decimal?       @db.Decimal(14, 4)
  salePrice   Decimal?       @db.Decimal(14, 4)
  avgCost     Decimal?       @db.Decimal(14, 4)
  minStock    Decimal        @default(0) @db.Decimal(14, 4)
  isActive    Boolean        @default(true)
  batches        Batch[]       @relation("BatchProduct")
  boms           BomVersion[]  @relation("ProductBoms")
  usedInBoms     BomItem[]     @relation("ComponentOf")
  routingSteps   RoutingStep[] @relation("ProductRouting")
  stockBalances  StockBalance[]
  stockMovements StockMovement[]
  poItems              POItem[]
  grItems              GRItem[]
  saleItems            SaleItem[]
  transferItems        StoreTransferItem[]
  demandForecasts      DemandForecast[]
  purchaseRequests     PurchaseRequest[]
  supplierPriceHistory SupplierPriceHistory[]
  mrpSuggestions            MrpSuggestion[]
  productionOrdersAsProduct ProductionOrder[]   @relation("ProductionOrderProduct")
  productionOrderItems      ProductionOrderItem[] @relation("ProductionOrderComponent")
  putawayTasks              PutawayTask[]        @relation("PutawayProduct")
  pickTasks                 PickTask[]           @relation("PickTaskProduct")
  inventoryItems            InventoryCountItem[] @relation("InventoryItemProduct")
  nonConformances           NonConformance[]     @relation("NcrProduct")
  serialNumbers             SerialNumber[]       @relation("SerialProduct")
  quotationItems            QuotationItem[]      @relation("QuotationItemProduct")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([companyId, sku])
  @@map("gdr_products")
}

// ─── Fornecedor ───────────────────────────────────────────────────────────────

model Supplier {
  id             String          @id @default(cuid())
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id])
  name           String
  cnpj           String?
  email          String?
  phone          String?
  leadTimeDays   Int             @default(0)
  isActive       Boolean         @default(true)
  purchaseOrders       PurchaseOrder[]
  supplierPriceHistory SupplierPriceHistory[]
  nonConformances      NonConformance[]
  portalTokens         SupplierToken[]
  batches              Batch[]               @relation("BatchSupplier")
  createdAt            DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([companyId, cnpj])
  @@map("gdr_suppliers")
}

// ─── Cliente ──────────────────────────────────────────────────────────────────

enum CustomerType {
  INDIVIDUAL
  COMPANY
}

model Customer {
  id           String       @id @default(cuid())
  companyId    String
  company      Company      @relation(fields: [companyId], references: [id])
  type         CustomerType @default(COMPANY)
  name         String
  document     String?
  email        String?
  phone        String?
  address      String?
  city         String?
  state        String?
  isActive     Boolean      @default(true)
  salesOrders  SalesOrder[]
  quotations   Quotation[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([companyId, document])
  @@map("gdr_customers")
}

// ─── BOM — Bill of Materials ──────────────────────────────────────────────────

model BomVersion {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  productId   String
  product     Product   @relation("ProductBoms", fields: [productId], references: [id])
  version     Int
  isActive    Boolean   @default(false)
  notes       String?
  items       BomItem[]
  createdAt   DateTime  @default(now())

  @@unique([productId, version])
  @@map("gdr_bom_versions")
}

model BomItem {
  id           String     @id @default(cuid())
  bomVersionId String
  bomVersion   BomVersion @relation(fields: [bomVersionId], references: [id], onDelete: Cascade)
  componentId  String
  component    Product    @relation("ComponentOf", fields: [componentId], references: [id])
  quantity     Decimal    @db.Decimal(14, 4)
  scrapPct     Decimal    @default(0) @db.Decimal(5, 2)
  unit         UnitOfMeasure @default(UN)

  @@map("gdr_bom_items")
}

// ─── Roteiro de Produção ─────────────────────────────────────────────────────

model RoutingStep {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  productId       String
  product         Product  @relation("ProductRouting", fields: [productId], references: [id])
  stepOrder       Int
  name            String
  workCenter      String?
  setupTimeMin    Int      @default(0)
  runTimeMin      Int      @default(0)
  notes           String?
  productionLogs  ProductionLog[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([productId, stepOrder])
  @@map("gdr_routing_steps")
}

// ─── Estoque ──────────────────────────────────────────────────────────────────

enum MovementType {
  ENTRY
  EXIT
  ADJUSTMENT
  REVERSAL
  TRANSFER_OUT
  TRANSFER_IN
}

model Warehouse {
  id          String          @id @default(cuid())
  companyId   String
  company     Company         @relation(fields: [companyId], references: [id])
  name        String
  code        String
  description String?
  isActive    Boolean         @default(true)
  wmsEnabled       Boolean         @default(false)
  batches          Batch[]
  balances         StockBalance[]
  movements        StockMovement[]
  goodsReceipts    GoodsReceipt[]
  salesOrders      SalesOrder[]
  transfersFrom    StoreTransfer[] @relation("TransferFrom")
  transfersTo      StoreTransfer[] @relation("TransferTo")
  productionOrders ProductionOrder[]
  locations        Location[]
  receivingOrders  ReceivingOrder[]
  pickingOrders    PickingOrder[]
  inventoryCounts  InventoryCount[]
  serialNumbers    SerialNumber[]
  quotations       Quotation[]
  createdAt     DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([companyId, code])
  @@map("gdr_warehouses")
}

model StockBalance {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  available       Decimal   @default(0) @db.Decimal(14, 4)
  reserved        Decimal   @default(0) @db.Decimal(14, 4)
  inTransit       Decimal   @default(0) @db.Decimal(14, 4)
  pendingPutaway  Decimal   @default(0) @db.Decimal(14, 4)
  updatedAt       DateTime  @updatedAt

  @@unique([warehouseId, productId])
  @@map("gdr_stock_balances")
}

model StockMovement {
  id           String       @id @default(cuid())
  companyId    String
  company      Company      @relation(fields: [companyId], references: [id])
  warehouseId  String
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id])
  productId    String
  product      Product      @relation(fields: [productId], references: [id])
  type         MovementType
  quantity     Decimal      @db.Decimal(14, 4)
  reason       String
  reference    String?
  reversedById String?
  userId       String?
  user         User?        @relation(fields: [userId], references: [id])
  createdAt    DateTime     @default(now())

  @@map("gdr_stock_movements")
}

// ─── Compras ──────────────────────────────────────────────────────────────────

enum PurchaseRequestStatus {
  OPEN
  APPROVED
  CONVERTED
  CANCELLED
}

model PurchaseRequest {
  id              String                @id @default(cuid())
  companyId       String
  company         Company               @relation(fields: [companyId], references: [id])
  productId       String
  product         Product               @relation(fields: [productId], references: [id])
  quantity        Decimal               @db.Decimal(14, 4)
  unit            UnitOfMeasure         @default(UN)
  neededBy        DateTime?
  justification   String?
  status          PurchaseRequestStatus @default(OPEN)
  requestedById   String?
  requestedBy     User?                 @relation("PRRequestedBy", fields: [requestedById], references: [id])
  convertedToId   String?
  convertedTo     PurchaseOrder?        @relation("PRConvertedTo", fields: [convertedToId], references: [id])
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([companyId, status])
  @@map("gdr_purchase_requests")
}

model SupplierPriceHistory {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  unitCost    Decimal  @db.Decimal(14, 4)
  goodsReceiptId String?
  recordedAt  DateTime @default(now())

  @@index([supplierId, productId])
  @@index([companyId])
  @@map("gdr_supplier_price_history")
}

enum PurchaseOrderStatus {
  DRAFT
  APPROVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  companyId    String
  company      Company             @relation(fields: [companyId], references: [id])
  supplierId   String
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  status       PurchaseOrderStatus @default(DRAFT)
  expectedAt   DateTime?
  notes        String?
  createdById  String?
  createdBy    User?               @relation("POCreatedBy", fields: [createdById], references: [id])
  approvedById String?
  approvedBy   User?               @relation("POApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  items                POItem[]
  receipts             GoodsReceipt[]
  financialEntries     FinancialEntry[]
  convertedFromRequests PurchaseRequest[] @relation("PRConvertedTo")
  inboundNfes          InboundNfe[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@map("gdr_purchase_orders")
}

model POItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Decimal       @db.Decimal(14, 4)
  unitCost        Decimal       @db.Decimal(14, 4)
  unit            UnitOfMeasure @default(UN)
  grItems         GRItem[]

  @@map("gdr_po_items")
}

model GoodsReceipt {
  id              String        @id @default(cuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  warehouseId     String
  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id])
  receivedById    String?
  receivedBy      User?         @relation("GRReceivedBy", fields: [receivedById], references: [id])
  notes            String?
  items            GRItem[]
  batches          Batch[]
  financialEntry   FinancialEntry?
  receivingOrder   ReceivingOrder?
  inspections      Inspection[]
  inboundNfe       InboundNfe?
  createdAt        DateTime      @default(now())

  @@map("gdr_goods_receipts")
}

model GRItem {
  id               String       @id @default(cuid())
  goodsReceiptId   String
  goodsReceipt     GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  poItemId         String
  poItem           POItem       @relation(fields: [poItemId], references: [id])
  productId        String
  product          Product      @relation(fields: [productId], references: [id])
  qtyOrdered       Decimal      @db.Decimal(14, 4)
  qtyReceived      Decimal      @db.Decimal(14, 4)
  divergenceReason String?

  @@map("gdr_gr_items")
}

// ─── Vendas ───────────────────────────────────────────────────────────────────

enum SalesOrderStatus {
  DRAFT
  RESERVED
  CONFIRMED
  INVOICED
  RETURNED
  CANCELLED
}

model SalesOrder {
  id          String           @id @default(cuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id])
  customerId  String?
  customer    Customer?        @relation(fields: [customerId], references: [id])
  warehouseId String
  warehouse   Warehouse        @relation(fields: [warehouseId], references: [id])
  status      SalesOrderStatus @default(DRAFT)
  notes       String?
  createdById String?
  createdBy   User?            @relation("SOCreatedBy", fields: [createdById], references: [id])
  confirmedAt DateTime?
  invoicedAt  DateTime?
  returnedAt  DateTime?
  cancelledAt DateTime?
  items            SaleItem[]
  fiscalDocument   FiscalDocument?
  financialEntry   FinancialEntry?
  pickingOrder     PickingOrder?
  serialNumbers    SerialNumber[]
  quotation        Quotation?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("gdr_sales_orders")
}

model SaleItem {
  id           String        @id @default(cuid())
  salesOrderId String
  salesOrder   SalesOrder    @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product       @relation(fields: [productId], references: [id])
  quantity     Decimal       @db.Decimal(14, 4)
  unitPrice    Decimal       @db.Decimal(14, 4)
  unit         UnitOfMeasure @default(UN)

  @@map("gdr_sale_items")
}

// ─── Fiscal ───────────────────────────────────────────────────────────────────

enum FiscalDocumentType {
  NFE
  NFCE
}

enum FiscalStatus {
  PENDING
  PROCESSING
  AUTHORIZED
  REJECTED
  CANCELLED
  ERROR
}

model FiscalDocument {
  id               String             @id @default(cuid())
  companyId        String
  company          Company            @relation(fields: [companyId], references: [id])
  salesOrderId     String?            @unique
  salesOrder       SalesOrder?        @relation(fields: [salesOrderId], references: [id])
  storeTransferId  String?            @unique
  storeTransfer    StoreTransfer?     @relation(fields: [storeTransferId], references: [id])
  type             FiscalDocumentType @default(NFCE)
  status           FiscalStatus       @default(PENDING)
  focusRef         String?
  chave            String?
  xml              String?
  rejectionCode    String?
  rejectionReason  String?
  retryCount       Int                @default(0)
  lastError        String?
  financialEntry   FinancialEntry?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@map("gdr_fiscal_documents")
}

// ─── Financeiro ───────────────────────────────────────────────────────────────

enum FinancialEntryType {
  RECEIVABLE
  PAYABLE
}

enum FinancialEntryStatus {
  OPEN
  OVERDUE
  PAID
  CANCELLED
}

model FinancialEntry {
  id               String               @id @default(cuid())
  companyId        String
  company          Company              @relation(fields: [companyId], references: [id])
  type             FinancialEntryType
  status           FinancialEntryStatus @default(OPEN)
  amount           Decimal              @db.Decimal(14, 4)
  dueDate          DateTime
  description      String?
  salesOrderId     String?              @unique
  salesOrder       SalesOrder?          @relation(fields: [salesOrderId], references: [id])
  purchaseOrderId  String?
  purchaseOrder    PurchaseOrder?       @relation(fields: [purchaseOrderId], references: [id])
  goodsReceiptId   String?              @unique
  goodsReceipt     GoodsReceipt?        @relation(fields: [goodsReceiptId], references: [id])
  fiscalDocumentId String?              @unique
  fiscalDocument   FiscalDocument?      @relation(fields: [fiscalDocumentId], references: [id])
  paidAt           DateTime?
  paidAmount       Decimal?             @db.Decimal(14, 4)
  paymentNote      String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([companyId])
  @@index([type, status])
  @@index([dueDate])
  @@map("gdr_financial_entries")
}

model BankAccount {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  bank      String?
  agency    String?
  account   String?
  balance   Decimal   @default(0) @db.Decimal(14, 4)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([companyId])
  @@map("gdr_bank_accounts")
}

// ─── Transferências fábrica → loja ───────────────────────────────────────────

enum TransferStatus {
  DRAFT
  DISPATCHED
  RECEIVED
  CANCELLED
}

model StoreTransfer {
  id              String         @id @default(cuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  fromWarehouseId String
  fromWarehouse   Warehouse      @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String
  toWarehouse     Warehouse      @relation("TransferTo", fields: [toWarehouseId], references: [id])
  status          TransferStatus @default(DRAFT)
  notes           String?
  requestedById   String?
  requestedBy     User?          @relation("TransferRequestedBy", fields: [requestedById], references: [id])
  dispatchedById  String?
  dispatchedBy    User?          @relation("TransferDispatchedBy", fields: [dispatchedById], references: [id])
  dispatchedAt    DateTime?
  receivedById    String?
  receivedBy      User?          @relation("TransferReceivedBy", fields: [receivedById], references: [id])
  receivedAt      DateTime?
  cancelledAt     DateTime?
  items           StoreTransferItem[]
  fiscalDocument  FiscalDocument?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([companyId])
  @@index([status])
  @@map("gdr_store_transfers")
}

model StoreTransferItem {
  id              String        @id @default(cuid())
  storeTransferId String
  storeTransfer   StoreTransfer @relation(fields: [storeTransferId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Decimal       @db.Decimal(14, 4)
  unit            UnitOfMeasure @default(UN)

  @@map("gdr_store_transfer_items")
}

// ─── Configurações do Sistema ─────────────────────────────────────────────────

model SystemParameter {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, key])
  @@map("gdr_system_parameters")
}

// ─── MRP Engine ──────────────────────────────────────────────────────────────

enum MrpRunStatus {
  RUNNING
  DONE
  ERROR
}

enum MrpSuggestionType {
  PURCHASE
  PRODUCTION
}

model MrpRun {
  id           String        @id @default(cuid())
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id])
  horizonDays  Int
  status       MrpRunStatus  @default(RUNNING)
  errorMessage String?
  suggestions  MrpSuggestion[]
  triggeredById String?
  triggeredBy   User?        @relation("MrpTriggeredBy", fields: [triggeredById], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([companyId])
  @@map("gdr_mrp_runs")
}

model MrpSuggestion {
  id            String             @id @default(cuid())
  mrpRunId      String
  mrpRun        MrpRun             @relation(fields: [mrpRunId], references: [id], onDelete: Cascade)
  productId     String
  product       Product            @relation(fields: [productId], references: [id])
  type          MrpSuggestionType
  grossQty      Decimal            @db.Decimal(14, 4)  // demanda bruta do período
  stockOnHand   Decimal            @db.Decimal(14, 4)  // estoque disponível atual
  netQty        Decimal            @db.Decimal(14, 4)  // necessidade líquida (gross - stock)
  bomLevel      Int                @default(0)         // 0=produto final, 1+=componente
  suggestedDate DateTime?
  notes         String?
  createdAt     DateTime           @default(now())

  @@index([mrpRunId])
  @@index([productId])
  @@map("gdr_mrp_suggestions")
  productionOrders ProductionOrder[]
}

// ─── Ordens de Produção ───────────────────────────────────────────────────────

enum ProductionOrderStatus {
  DRAFT
  RELEASED
  IN_PROGRESS
  DONE
  CANCELLED
}

model ProductionLog {
  id                String          @id @default(cuid())
  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  routingStepId     String?
  routingStep       RoutingStep?    @relation(fields: [routingStepId], references: [id])
  stepOrder         Int?            // cache do stepOrder para ordenação
  workCenter        String?
  qty               Decimal         @db.Decimal(14, 4)
  userId            String?
  user              User?           @relation("ProductionLogUser", fields: [userId], references: [id])
  notes             String?
  loggedAt          DateTime        @default(now()) @map("logged_at")

  @@index([productionOrderId])
  @@map("gdr_production_log")
}

model ProductionOrder {
  id               String                @id @default(cuid())
  companyId        String
  company          Company               @relation(fields: [companyId], references: [id])
  productId        String
  product          Product               @relation("ProductionOrderProduct", fields: [productId], references: [id])
  warehouseId      String
  warehouse        Warehouse             @relation(fields: [warehouseId], references: [id])
  mrpSuggestionId  String?
  mrpSuggestion    MrpSuggestion?        @relation(fields: [mrpSuggestionId], references: [id])
  plannedQty       Decimal               @db.Decimal(14, 4)
  producedQty      Decimal               @default(0) @db.Decimal(14, 4)
  status           ProductionOrderStatus @default(DRAFT)
  scheduledStart   DateTime?
  scheduledEnd     DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  notes            String?
  items            ProductionOrderItem[]
  logs             ProductionLog[]
  cost             ProductionCost?
  inspections      Inspection[]
  serialNumbers    SerialNumber[]
  batchEvents      BatchEvent[]
  createdById      String?
  createdBy        User?                 @relation("POProdCreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([companyId, status])
  @@map("gdr_production_orders")
}

model ProductionCost {
  id                String          @id @default(cuid())
  productionOrderId String          @unique
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  materialCost      Decimal         @default(0) @db.Decimal(14, 4)
  laborCost         Decimal         @default(0) @db.Decimal(14, 4)
  totalCost         Decimal         @default(0) @db.Decimal(14, 4)
  costPerUnit       Decimal         @default(0) @db.Decimal(14, 4)
  breakdown         Json            @default("[]")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("gdr_production_costs")
}

model ProductionOrderItem {
  id                String          @id @default(cuid())
  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  componentId       String
  component         Product         @relation("ProductionOrderComponent", fields: [componentId], references: [id])
  plannedQty        Decimal         @db.Decimal(14, 4)
  consumedQty       Decimal         @default(0) @db.Decimal(14, 4)
  unit              UnitOfMeasure   @default(UN)

  @@map("gdr_production_order_items")
}

// ─── WMS ─────────────────────────────────────────────────────────────────────

enum LocationType {
  RECEIVING
  STORAGE
  STAGING
}

enum ReceivingStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum PutawayStatus {
  PENDING
  CONFIRMED
}

model Location {
  id          String       @id @default(cuid())
  companyId   String
  company     Company      @relation(fields: [companyId], references: [id])
  warehouseId String
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id])
  code        String
  description String?
  type        LocationType @default(STORAGE)
  isActive    Boolean      @default(true)
  putawayTasks PutawayTask[]
  pickTasks    PickTask[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([warehouseId, code])
  @@index([companyId])
  @@map("gdr_locations")
}

model ReceivingOrder {
  id             String          @id @default(cuid())
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id])
  goodsReceiptId String          @unique
  goodsReceipt   GoodsReceipt    @relation(fields: [goodsReceiptId], references: [id])
  warehouseId    String
  warehouse      Warehouse       @relation(fields: [warehouseId], references: [id])
  status         ReceivingStatus @default(PENDING)
  tasks          PutawayTask[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([companyId, status])
  @@map("gdr_receiving_orders")
}

model PutawayTask {
  id               String         @id @default(cuid())
  companyId        String
  company          Company        @relation(fields: [companyId], references: [id])
  receivingOrderId String
  receivingOrder   ReceivingOrder @relation(fields: [receivingOrderId], references: [id], onDelete: Cascade)
  productId        String
  product          Product        @relation("PutawayProduct", fields: [productId], references: [id])
  qty              Decimal        @db.Decimal(14, 4)
  locationId       String?
  location         Location?      @relation(fields: [locationId], references: [id])
  status           PutawayStatus  @default(PENDING)
  confirmedById    String?
  confirmedBy      User?          @relation("PutawayConfirmedBy", fields: [confirmedById], references: [id])
  confirmedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([receivingOrderId])
  @@index([companyId, status])
  @@map("gdr_putaway_tasks")
}

// ─── WMS Saída ────────────────────────────────────────────────────────────────

enum PickingStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum PickTaskStatus {
  PENDING
  CONFIRMED
}

model PickingOrder {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  salesOrderId  String        @unique
  salesOrder    SalesOrder    @relation(fields: [salesOrderId], references: [id])
  warehouseId   String
  warehouse     Warehouse     @relation(fields: [warehouseId], references: [id])
  status        PickingStatus @default(PENDING)
  tasks         PickTask[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([companyId, status])
  @@map("gdr_picking_orders")
}

model PickTask {
  id             String         @id @default(cuid())
  companyId      String
  company        Company        @relation(fields: [companyId], references: [id])
  pickingOrderId String
  pickingOrder   PickingOrder   @relation(fields: [pickingOrderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product        @relation("PickTaskProduct", fields: [productId], references: [id])
  qty            Decimal        @db.Decimal(14, 4)
  locationId     String?
  location       Location?      @relation(fields: [locationId], references: [id])
  notes          String?
  status         PickTaskStatus @default(PENDING)
  confirmedById  String?
  confirmedBy    User?          @relation("PickConfirmedBy", fields: [confirmedById], references: [id])
  confirmedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([pickingOrderId])
  @@index([companyId, status])
  @@map("gdr_pick_tasks")
}

// ─── WMS Inventário ───────────────────────────────────────────────────────────

enum InventoryCountType {
  CYCLIC
  FULL
}

enum InventoryCountStatus {
  DRAFT
  IN_PROGRESS
  RECONCILED
  CANCELLED
}

enum InventoryItemStatus {
  PENDING
  COUNTED
}

model InventoryCount {
  id             String               @id @default(cuid())
  companyId      String
  company        Company              @relation(fields: [companyId], references: [id])
  warehouseId    String
  warehouse      Warehouse            @relation(fields: [warehouseId], references: [id])
  type           InventoryCountType   @default(CYCLIC)
  status         InventoryCountStatus @default(DRAFT)
  notes          String?
  createdById    String?
  createdBy      User?                @relation("InventoryCreatedBy", fields: [createdById], references: [id])
  reconciledById String?
  reconciledBy   User?                @relation("InventoryReconciledBy", fields: [reconciledById], references: [id])
  reconciledAt   DateTime?
  items          InventoryCountItem[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([companyId, status])
  @@index([warehouseId])
  @@map("gdr_inventory_counts")
}

model InventoryCountItem {
  id               String              @id @default(cuid())
  companyId        String
  company          Company             @relation(fields: [companyId], references: [id])
  inventoryCountId String
  inventoryCount   InventoryCount      @relation(fields: [inventoryCountId], references: [id], onDelete: Cascade)
  productId        String
  product          Product             @relation("InventoryItemProduct", fields: [productId], references: [id])
  systemQty        Decimal             @db.Decimal(14, 4)
  countedQty       Decimal?            @db.Decimal(14, 4)
  variance         Decimal?            @db.Decimal(14, 4)
  status           InventoryItemStatus @default(PENDING)
  countedById      String?
  countedBy        User?               @relation("InventoryItemCountedBy", fields: [countedById], references: [id])
  countedAt        DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([inventoryCountId, productId])
  @@index([inventoryCountId])
  @@index([companyId, status])
  @@map("gdr_inventory_count_items")
}

// ─── Demanda (MRP) ────────────────────────────────────────────────────────────

model DemandForecast {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  period      String   // YYYY-MM (ex: "2026-05")
  quantity    Decimal  @db.Decimal(14, 4)
  notes       String?
  createdById String?
  createdBy   User?    @relation("DemandCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, productId, period])
  @@index([companyId])
  @@index([period])
  @@index([productId])
  @@map("gdr_demand_forecasts")
}

// ─── Alertas (S24) ───────────────────────────────────────────────────────────

enum AlertType {
  STOCK_MIN
  PAYABLE_DUE
  PRODUCTION_LATE
  NFE_REJECTED
  MRP_RUN_DONE
  FOCUS_NFE_DOWN
  QC_INSPECTION_FAILED
  MAINTENANCE_DUE
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model Alert {
  id          String        @id @default(cuid())
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id])
  type        AlertType
  severity    AlertSeverity @default(WARNING)
  title       String
  body        String
  entityId    String?
  entityType  String?
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())

  @@index([companyId, resolvedAt])
  @@index([type])
  @@map("gdr_alerts")
}

// ─── Qualidade (S25) ─────────────────────────────────────────────────────────

enum InspectionType {
  RECEIVING
  IN_PROCESS
  FINAL
}

enum InspectionStatus {
  PENDING
  IN_PROGRESS
  PASSED
  FAILED
  ON_HOLD
}

enum NcrStatus {
  OPEN
  UNDER_ANALYSIS
  CORRECTIVE_ACTION
  CLOSED
  CANCELLED
}

enum NcrSeverity {
  MINOR
  MAJOR
  CRITICAL
}

model Inspection {
  id                String           @id @default(cuid())
  companyId         String
  company           Company          @relation(fields: [companyId], references: [id])
  type              InspectionType
  status            InspectionStatus @default(PENDING)
  goodsReceiptId    String?
  goodsReceipt      GoodsReceipt?    @relation(fields: [goodsReceiptId], references: [id])
  productionOrderId String?
  productionOrder   ProductionOrder? @relation(fields: [productionOrderId], references: [id])
  notes             String?
  inspectedById     String?
  inspectedBy       User?            @relation("InspectionInspectedBy", fields: [inspectedById], references: [id])
  startedAt         DateTime?
  finishedAt        DateTime?
  nonConformances   NonConformance[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([companyId, status])
  @@index([goodsReceiptId])
  @@index([productionOrderId])
  @@map("gdr_inspections")
}

model NonConformance {
  id               String      @id @default(cuid())
  companyId        String
  company          Company     @relation(fields: [companyId], references: [id])
  inspectionId     String?
  inspection       Inspection? @relation(fields: [inspectionId], references: [id])
  productId        String?
  product          Product?    @relation("NcrProduct", fields: [productId], references: [id])
  supplierId       String?
  supplier         Supplier?   @relation(fields: [supplierId], references: [id])
  title            String
  description      String
  severity         NcrSeverity @default(MAJOR)
  status           NcrStatus   @default(OPEN)
  rootCause        String?
  correctiveAction String?
  responsibleId    String?
  responsible      User?       @relation("NcrResponsible", fields: [responsibleId], references: [id])
  dueDate          DateTime?
  closedAt         DateTime?
  closedById       String?
  closedBy         User?       @relation("NcrClosedBy", fields: [closedById], references: [id])
  createdById      String?
  createdBy        User?       @relation("NcrCreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([companyId, status])
  @@index([supplierId])
  @@index([productId])
  @@map("gdr_non_conformances")
}

// ─── Rastreabilidade por Número de Série/Chassi (S27A) ───────────────────────

enum SerialStatus {
  IN_PRODUCTION
  IN_STOCK
  SOLD
  TRANSFERRED
  SCRAPPED
}

model SerialNumber {
  id                 String           @id @default(dbgenerated("gen_random_uuid()"))
  companyId          String           @map("company_id")
  company            Company          @relation(fields: [companyId], references: [id])
  productId          String           @map("product_id")
  product            Product          @relation("SerialProduct", fields: [productId], references: [id])
  warehouseId        String?          @map("warehouse_id")
  warehouse          Warehouse?       @relation(fields: [warehouseId], references: [id])
  serial             String           @unique
  status             SerialStatus     @default(IN_STOCK)
  productionOrderId  String?          @map("production_order_id")
  productionOrder    ProductionOrder? @relation(fields: [productionOrderId], references: [id])
  salesOrderId       String?          @map("sales_order_id")
  salesOrder         SalesOrder?      @relation(fields: [salesOrderId], references: [id])
  producedAt         DateTime?        @map("produced_at")
  soldAt             DateTime?        @map("sold_at")
  legacyId           Int?             @map("legacy_id")
  legacyOsId         Int?             @map("legacy_os_id")
  engravingStartedAt DateTime?        @map("engraving_started_at")
  engravingDoneAt    DateTime?        @map("engraving_done_at")
  engravingOperator  String?          @map("engraving_operator")
  observations       String?
  createdAt          DateTime         @default(now()) @map("created_at")

  @@index([companyId, status])
  @@index([productId, status])
  @@map("gdr_serial_number")
}

// ─── Manutenção de Equipamentos (S27B) ───────────────────────────────────────

enum EquipmentStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  SCRAPPED
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  CALIBRATION
  INSPECTION
}

enum MaintenanceOrderStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

model Equipment {
  id               String          @id @default(cuid())
  companyId        String
  company          Company         @relation(fields: [companyId], references: [id])
  code             String
  name             String
  description      String?
  location         String?
  status           EquipmentStatus @default(ACTIVE)
  acquisitionDate  DateTime?
  nextMaintenanceAt DateTime?
  maintenanceIntervalDays Int      @default(30)
  maintenanceOrders MaintenanceOrder[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([companyId, code])
  @@index([companyId, status])
  @@map("gdr_equipment")
}

model MaintenanceOrder {
  id           String                 @id @default(cuid())
  companyId    String
  company      Company                @relation(fields: [companyId], references: [id])
  equipmentId  String
  equipment    Equipment              @relation(fields: [equipmentId], references: [id])
  type         MaintenanceType        @default(PREVENTIVE)
  status       MaintenanceOrderStatus @default(OPEN)
  title        String
  description  String?
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  technicianId String?
  technician   User?                  @relation("MaintenanceTechnician", fields: [technicianId], references: [id])
  resolution   String?
  cost         Decimal?               @db.Decimal(14, 4)
  createdById  String?
  createdBy    User?                  @relation("MaintenanceCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([companyId, status])
  @@index([equipmentId])
  @@map("gdr_maintenance_orders")
}

// ─── Orçamentos / Propostas Comerciais (S28A) ─────────────────────────────────

enum QuotationStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

model Quotation {
  id           String          @id @default(cuid())
  companyId    String
  company      Company         @relation(fields: [companyId], references: [id])
  customerId   String?
  customer     Customer?       @relation(fields: [customerId], references: [id])
  warehouseId  String
  warehouse    Warehouse       @relation(fields: [warehouseId], references: [id])
  status       QuotationStatus @default(DRAFT)
  validUntil   DateTime?
  notes        String?
  discount     Decimal         @default(0) @db.Decimal(5, 2)
  items        QuotationItem[]
  salesOrder   SalesOrder?     @relation(fields: [salesOrderId], references: [id])
  salesOrderId String?         @unique
  createdById  String?
  createdBy    User?           @relation("QuotationCreatedBy", fields: [createdById], references: [id])
  sentAt       DateTime?
  approvedAt   DateTime?
  rejectedAt   DateTime?
  rejectionReason String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([companyId, status])
  @@index([customerId])
  @@map("gdr_quotations")
}

model QuotationItem {
  id           String    @id @default(cuid())
  quotationId  String
  quotation    Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId    String
  product      Product   @relation("QuotationItemProduct", fields: [productId], references: [id])
  quantity     Decimal   @db.Decimal(14, 4)
  unitPrice    Decimal   @db.Decimal(14, 4)
  discount     Decimal   @default(0) @db.Decimal(5, 2)
  unit         UnitOfMeasure @default(UN)

  @@map("gdr_quotation_items")
}

// ─── Portal do Fornecedor (S27C) ─────────────────────────────────────────────

model SupplierToken {
  id          String    @id @default(cuid())
  supplierId  String
  supplier    Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  token       String    @unique @default(cuid())
  description String?   // e.g. "Token para integração ERP cliente"
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([supplierId])
  @@map("gdr_supplier_tokens")
}

// ─── NF-e de Entrada (S28B) ──────────────────────────────────────────────────

enum InboundNfeStatus {
  PENDING
  MATCHED
  IMPORTED
  REJECTED
}

model InboundNfe {
  id              String           @id @default(cuid())
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])
  chaveNfe        String           @unique  // 44-digit key
  nfeNumber       String?
  series          String?
  supplierCnpj    String
  supplierName    String
  issueDate       DateTime?
  totalValue      Decimal?         @db.Decimal(14, 4)
  status          InboundNfeStatus @default(PENDING)
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id])
  goodsReceiptId  String?          @unique
  goodsReceipt    GoodsReceipt?    @relation(fields: [goodsReceiptId], references: [id])
  xmlContent      String           // raw XML
  parsedItems     Json             // array of { ncm, description, quantity, unitPrice, totalPrice }
  rejectReason    String?
  importedById    String?
  importedBy      User?            @relation("InboundNfeImportedBy", fields: [importedById], references: [id])
  importedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([companyId, status])
  @@index([supplierCnpj])
  @@map("gdr_inbound_nfe")
}

// ─── Planejamento de Capacidade (S28C) ───────────────────────────────────────

model WorkCenter {
  id                  String   @id @default(cuid())
  companyId           String
  company             Company  @relation(fields: [companyId], references: [id])
  code                String
  name                String
  description         String?
  capacityHoursPerDay Decimal  @default(8) @db.Decimal(5, 2)
  operatorsCount      Int      @default(1)
  efficiencyPct       Decimal  @default(85) @db.Decimal(5, 2)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
  @@map("gdr_work_centers")
}

// ─── Gestão de Lotes (S28D) ──────────────────────────────────────────────────

enum BatchStatus {
  ACTIVE
  QUARANTINE
  CONSUMED
  EXPIRED
  SCRAPPED
}

enum BatchEventType {
  RECEIPT
  TRANSFER
  CONSUMPTION
  ADJUSTMENT
  QUARANTINE
  RELEASE
  EXPIRY
  SCRAP
}

model Batch {
  id                 String      @id @default(cuid())
  companyId          String
  company            Company     @relation(fields: [companyId], references: [id])
  batchNumber        String
  productId          String
  product            Product     @relation("BatchProduct", fields: [productId], references: [id])
  supplierId         String?
  supplier           Supplier?   @relation("BatchSupplier", fields: [supplierId], references: [id])
  goodsReceiptId     String?
  goodsReceipt       GoodsReceipt? @relation(fields: [goodsReceiptId], references: [id])
  status             BatchStatus @default(ACTIVE)
  initialQty         Decimal     @db.Decimal(14, 4)
  currentQty         Decimal     @db.Decimal(14, 4)
  unit               UnitOfMeasure @default(UN)
  manufacturingDate  DateTime?
  expirationDate     DateTime?
  warehouseId        String?
  warehouse          Warehouse?  @relation(fields: [warehouseId], references: [id])
  notes              String?
  events             BatchEvent[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@unique([companyId, batchNumber, productId])
  @@index([companyId, status])
  @@index([productId])
  @@index([expirationDate])
  @@map("gdr_batches")
}

model BatchEvent {
  id                  String         @id @default(cuid())
  batchId             String
  batch               Batch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  type                BatchEventType
  quantity            Decimal        @db.Decimal(14, 4)
  qtyBefore           Decimal        @db.Decimal(14, 4)
  qtyAfter            Decimal        @db.Decimal(14, 4)
  productionOrderId   String?
  productionOrder     ProductionOrder? @relation(fields: [productionOrderId], references: [id])
  warehouseFromId     String?
  warehouseTo         String?
  reference           String?
  notes               String?
  userId              String?
  user                User?          @relation("BatchEventUser", fields: [userId], references: [id])
  createdAt           DateTime       @default(now())

  @@index([batchId])
  @@index([productionOrderId])
  @@map("gdr_batch_events")
}
