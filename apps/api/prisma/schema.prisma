// ─── Qualidade (S25) ─────────────────────────────────────────────────────────

enum InspectionType {
  RECEIVING
  IN_PROCESS
  FINAL
}

enum InspectionStatus {
  PENDING
  IN_PROGRESS
  PASSED
  FAILED
  ON_HOLD
}

enum NcrStatus {
  OPEN
  UNDER_ANALYSIS
  CORRECTIVE_ACTION
  CLOSED
  CANCELLED
}

enum NcrSeverity {
  MINOR
  MAJOR
  CRITICAL
}

model Inspection {
  id                String           @id @default(cuid())
  companyId         String
  company           Company          @relation(fields: [companyId], references: [id])
  type              InspectionType
  status            InspectionStatus @default(PENDING)
  goodsReceiptId    String?
  goodsReceipt      GoodsReceipt?    @relation(fields: [goodsReceiptId], references: [id])
  productionOrderId String?
  productionOrder   ProductionOrder? @relation(fields: [productionOrderId], references: [id])
  notes             String?
  inspectedById     String?
  inspectedBy       User?            @relation("InspectionInspectedBy", fields: [inspectedById], references: [id])
  startedAt         DateTime?
  finishedAt        DateTime?
  nonConformances   NonConformance[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([companyId, status])
  @@index([goodsReceiptId])
  @@index([productionOrderId])
  @@map("gdr_inspections")
}

model NonConformance {
  id               String      @id @default(cuid())
  companyId        String
  company          Company     @relation(fields: [companyId], references: [id])
  inspectionId     String?
  inspection       Inspection? @relation(fields: [inspectionId], references: [id])
  productId        String?
  product          Product?    @relation("NcrProduct", fields: [productId], references: [id])
  supplierId       String?
  supplier         Supplier?   @relation(fields: [supplierId], references: [id])
  title            String
  description      String
  severity         NcrSeverity @default(MAJOR)
  status           NcrStatus   @default(OPEN)
  rootCause        String?
  correctiveAction String?
  responsibleId    String?
  responsible      User?       @relation("NcrResponsible", fields: [responsibleId], references: [id])
  dueDate          DateTime?
  closedAt         DateTime?
  closedById       String?
  closedBy         User?       @relation("NcrClosedBy", fields: [closedById], references: [id])
  createdById      String?
  createdBy        User?       @relation("NcrCreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([companyId, status])
  @@index([supplierId])
  @@index([productId])
  @@map("gdr_non_conformances")
}

// ─── Rastreabilidade por Número de Série/Chassi (S27A) ───────────────────────

enum SerialStatus {
  IN_PRODUCTION
  IN_STOCK
  SOLD
  TRANSFERRED
  SCRAPPED
}

model SerialNumber {
  id                 String           @id @default(dbgenerated("gen_random_uuid()"))
  companyId          String           @map("company_id")
  company            Company          @relation(fields: [companyId], references: [id])
  productId          String           @map("product_id")
  product            Product          @relation("SerialProduct", fields: [productId], references: [id])
  warehouseId        String?          @map("warehouse_id")
  warehouse          Warehouse?       @relation(fields: [warehouseId], references: [id])
  serial             String           @unique
  status             SerialStatus     @default(IN_STOCK)
  productionOrderId  String?          @map("production_order_id")
  productionOrder    ProductionOrder? @relation(fields: [productionOrderId], references: [id])
  salesOrderId       String?          @map("sales_order_id")
  salesOrder         SalesOrder?      @relation(fields: [salesOrderId], references: [id])
  producedAt         DateTime?        @map("produced_at")
  soldAt             DateTime?        @map("sold_at")
  legacyId           Int?             @map("legacy_id")
  legacyOsId         Int?             @map("legacy_os_id")
  engravingStartedAt DateTime?        @map("engraving_started_at")
  engravingDoneAt    DateTime?        @map("engraving_done_at")
  engravingOperator  String?          @map("engraving_operator")
  observations       String?

  // ─── Dados veiculares (NF-e grupo veiculos_novos) ────────────────────────────
  chassi             String?          @db.VarChar(17)  // VIN 17 chars, idêntico ao BIN
  codigoCor          String?          @map("codigo_cor") @db.VarChar(4)
  descricaoCor       String?          @map("descricao_cor") @db.VarChar(40)
  pesoLiquido        Decimal?         @map("peso_liquido") @db.Decimal(10, 3) // toneladas
  pesoBruto          Decimal?         @map("peso_bruto") @db.Decimal(10, 3)   // PBT toneladas
  potenciaMotor      Int?             @default(0) @map("potencia_motor") // CV (0 p/ reboque)
  cilindrada         Int?             @default(0) // cm³ (0 p/ reboque)
  tipoCombustivel    String?          @default("99") @map("tipo_combustivel") @db.VarChar(2) // 99=sem motor
  numeroMotor        String?          @map("numero_motor") @db.VarChar(21)
  cmt                Decimal?         @db.Decimal(10, 3) // capacidade máx. tração (ton)
  distanciaEixos     Int?             @map("distancia_eixos") // mm
  anoFabricacao      Int?             @map("ano_fabricacao")
  anoModelo          Int?             @map("ano_modelo")
  tipoPintura        String?          @default("S") @map("tipo_pintura") @db.VarChar(1) // M=Metálica, S=Sólida, P=Perolizada
  tipoVeiculo        String?          @default("10") @map("tipo_veiculo") @db.VarChar(2) // 10=Reboque (RENAVAM)
  especieVeiculo     String?          @default("2") @map("especie_veiculo") @db.VarChar(1) // 2=Carga
  vin                String?          @default("N") @db.VarChar(1) // N=Normal, R=Remarcado
  condicaoVeiculo    String?          @default("1") @map("condicao_veiculo") @db.VarChar(1) // 1=Acabado
  codigoMarcaModelo  String?          @map("codigo_marca_modelo") @db.VarChar(6) // código RENAVAM
  corDenatran        String?          @map("cor_denatran") @db.VarChar(2) // código cor DENATRAN
  lotacao            Int?             @default(0) // 0 p/ reboque
  restricao          String?          @default("0") @db.VarChar(1) // 0=Sem restrição
  qtdEixos           Int?             @map("qtd_eixos")
  tipoOperacao       String?          @default("1") @map("tipo_operacao") @db.VarChar(1) // 1=Venda concessionária

  createdAt          DateTime         @default(now()) @map("created_at")
  saleItems          SaleItem[]       @relation("SaleItemSerial")
  components         SerialComponent[] @relation("SerialChassisComponents")

  @@index([companyId, status])
  @@index([productId, status])
  @@map("gdr_serial_number")
}

model SerialComponent {
  id                 String           @id @default(cuid())
  serialId           String
  serial             SerialNumber     @relation("SerialChassisComponents", fields: [serialId], references: [id])
  componentProductId String
  componentProduct   Product          @relation("SerialComponentProduct", fields: [componentProductId], references: [id])
  batchId            String?
  batch              Batch?           @relation("SerialComponentBatch", fields: [batchId], references: [id])
  quantity           Decimal          @db.Decimal(14, 4)
  productionOrderId  String
  productionOrder    ProductionOrder  @relation(fields: [productionOrderId], references: [id])
  consumedAt         DateTime         @default(now())

  @@index([serialId])
  @@index([batchId])
  @@index([productionOrderId])
  @@map("gdr_serial_components")
}

// ─── Manutenção de Equipamentos (S27B) ───────────────────────────────────────

enum EquipmentStatus {
  ACTIVE
  INACTIVE
  UNDER_MAINTENANCE
  SCRAPPED
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  CALIBRATION
  INSPECTION
}

enum MaintenanceOrderStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

model Equipment {
  id               String          @id @default(cuid())
  companyId        String
  company          Company         @relation(fields: [companyId], references: [id])
  code             String
  name             String
  description      String?
  location         String?
  status           EquipmentStatus @default(ACTIVE)
  acquisitionDate  DateTime?
  nextMaintenanceAt DateTime?
  maintenanceIntervalDays Int      @default(30)
  maintenanceOrders MaintenanceOrder[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([companyId, code])
  @@index([companyId, status])
  @@map("gdr_equipment")
}

model MaintenanceOrder {
  id           String                 @id @default(cuid())
  companyId    String
  company      Company                @relation(fields: [companyId], references: [id])
  equipmentId  String
  equipment    Equipment              @relation(fields: [equipmentId], references: [id])
  type         MaintenanceType        @default(PREVENTIVE)
  status       MaintenanceOrderStatus @default(OPEN)
  title        String
  description  String?
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  technicianId String?
  technician   User?                  @relation("MaintenanceTechnician", fields: [technicianId], references: [id])
  resolution   String?
  cost         Decimal?               @db.Decimal(14, 4)
  createdById  String?
  createdBy    User?                  @relation("MaintenanceCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([companyId, status])
  @@index([equipmentId])
  @@map("gdr_maintenance_orders")
}

// ─── Orçamentos / Propostas Comerciais (S28A) ─────────────────────────────────

enum QuotationStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

model Quotation {
  id           String          @id @default(cuid())
  companyId    String
  company      Company         @relation(fields: [companyId], references: [id])
  customerId   String?
  customer     Customer?       @relation(fields: [customerId], references: [id])
  warehouseId  String
  warehouse    Warehouse       @relation(fields: [warehouseId], references: [id])
  status       QuotationStatus @default(DRAFT)
  validUntil   DateTime?
  notes        String?
  discount     Decimal         @default(0) @db.Decimal(5, 2)
  items        QuotationItem[]
  salesOrder   SalesOrder?     @relation(fields: [salesOrderId], references: [id])
  salesOrderId String?         @unique
  createdById  String?
  createdBy    User?           @relation("QuotationCreatedBy", fields: [createdById], references: [id])
  sentAt       DateTime?
  approvedAt   DateTime?
  rejectedAt   DateTime?
  rejectionReason String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([companyId, status])
  @@index([customerId])
  @@map("gdr_quotations")
}

model QuotationItem {
  id           String    @id @default(cuid())
  quotationId  String
  quotation    Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId    String
  product      Product   @relation("QuotationItemProduct", fields: [productId], references: [id])
  quantity     Decimal   @db.Decimal(14, 4)
  unitPrice    Decimal   @db.Decimal(14, 4)
  discount     Decimal   @default(0) @db.Decimal(5, 2)
  unit         UnitOfMeasure @default(UN)

  @@map("gdr_quotation_items")
}

// ─── Portal do Fornecedor (S27C) ─────────────────────────────────────────────

model SupplierToken {
  id          String    @id @default(cuid())
  supplierId  String
  supplier    Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  token       String    @unique @default(cuid())
  description String?   // e.g. "Token para integração ERP cliente"
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([supplierId])
  @@map("gdr_supplier_tokens")
}

// ─── NF-e de Entrada (S28B) ──────────────────────────────────────────────────

enum InboundNfeStatus {
  PENDING
  MATCHED
  IMPORTED
  REJECTED
}

model InboundNfe {
  id              String           @id @default(cuid())
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])
  chaveNfe        String           @unique  // 44-digit key
  nfeNumber       String?
  series          String?
  supplierCnpj    String
  supplierName    String
  issueDate       DateTime?
  totalValue      Decimal?         @db.Decimal(14, 4)
  status          InboundNfeStatus @default(PENDING)
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id])
  goodsReceiptId  String?          @unique
  goodsReceipt    GoodsReceipt?    @relation(fields: [goodsReceiptId], references: [id])
  xmlContent      String           // raw XML
  parsedItems     Json             // array of { ncm, description, quantity, unitPrice, totalPrice }
  rejectReason    String?
  importedById    String?
  importedBy      User?            @relation("InboundNfeImportedBy", fields: [importedById], references: [id])
  importedAt      DateTime?
  threeWayMatches ThreeWayMatch[]
  nfeManifest     NfeManifest?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([companyId, status])
  @@index([supplierCnpj])
  @@map("gdr_inbound_nfe")
}

// ─── Manifestação do Destinatário (Fase 6) ──────────────────────────────────

enum ManifestStatus {
  PENDING        // NF-e detectada, aguardando ação
  CIENCIA        // Ciência da operação registrada
  CONFIRMED      // Operação confirmada
  NOT_PERFORMED  // Operação não realizada
  UNKNOWN        // Desconhecimento da operação
}

enum ManifestEventType {
  CIENCIA            // 210210 — Ciência da Operação
  CONFIRMACAO        // 210200 — Confirmação da Operação
  OPERACAO_NAO_REALIZADA // 210220 — Operação Não Realizada
  DESCONHECIMENTO    // 210240 — Desconhecimento da Operação
}

model NfeManifest {
  id              String         @id @default(cuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  chaveNfe        String         // 44-digit access key
  nfeNumber       String?
  series          String?
  supplierCnpj    String
  supplierName    String?
  issueDate       DateTime?
  totalValue      Decimal?       @db.Decimal(14, 4)
  status          ManifestStatus @default(PENDING)
  lastEventType   ManifestEventType?
  lastEventDate   DateTime?
  justification   String?        // Required for NOT_PERFORMED and UNKNOWN
  protocol        String?        // SEFAZ protocol returned
  inboundNfeId    String?        @unique
  inboundNfe      InboundNfe?    @relation(fields: [inboundNfeId], references: [id])
  manifestedById  String?
  manifestedBy    User?          @relation("NfeManifestBy", fields: [manifestedById], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([companyId, chaveNfe])
  @@index([companyId, status])
  @@index([supplierCnpj])
  @@map("gdr_nfe_manifests")
}

// ─── LGPD — Consentimento e Anonimização (Fase 7, #194) ─────────────────────

enum ConsentPurpose {
  COMMERCIAL       // Marketing, ofertas
  OPERATIONAL      // Necessário para operação (pedidos, NF-e)
  ANALYTICS        // Dados agregados para BI
}

enum ConsentStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AnonymizationStatus {
  REQUESTED
  PROCESSING
  COMPLETED
  DENIED
}

model ConsentRecord {
  id            String         @id @default(cuid())
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id])
  subjectType   String         // 'Customer' | 'User' | 'Supplier'
  subjectId     String         // ID da entidade
  document      String         // CPF/CNPJ do titular
  purpose       ConsentPurpose
  status        ConsentStatus  @default(ACTIVE)
  collectedAt   DateTime       @default(now())
  collectedBy   String?        // userId que registrou
  revokedAt     DateTime?
  expiresAt     DateTime?
  legalBasis    String?        // Base legal LGPD (Art. 7)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([companyId, document])
  @@index([companyId, subjectType, subjectId])
  @@map("gdr_consent_records")
}

model AnonymizationRequest {
  id            String              @id @default(cuid())
  companyId     String
  company       Company             @relation(fields: [companyId], references: [id])
  document      String              // CPF/CNPJ do titular
  subjectName   String?             // Nome original (apagado após conclusão)
  status        AnonymizationStatus @default(REQUESTED)
  requestedById String?
  requestedBy   User?               @relation("AnonymizationRequestedBy", fields: [requestedById], references: [id])
  processedAt   DateTime?
  entitiesAffected Json?            // { customers: 1, users: 0, suppliers: 0 }
  denialReason  String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([companyId, document])
  @@map("gdr_anonymization_requests")
}

// ─── Conciliação Bancária OFX (Fase 7, #197) ────────────────────────────────

model BankStatement {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  bankAccountId   String
  bankAccount     BankAccount @relation(fields: [bankAccountId], references: [id])
  transactionDate DateTime
  amount          Decimal  @db.Decimal(14, 4)
  description     String?
  reference       String?
  type            String   @default("DEBIT") // DEBIT | CREDIT
  fitId           String?  // OFX unique transaction ID
  matchStatus     String   @default("UNMATCHED") // MATCHED | UNMATCHED
  matchedEntryId  String?
  matchedAt       DateTime?
  importBatchId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId, bankAccountId])
  @@index([matchStatus])
  @@map("gdr_bank_statements")
}

// ─── Sequenciamento de Produção (Fase 7, #200) ──────────────────────────────

model ProductionSchedule {
  id                String   @id @default(cuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id])
  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id])
  workCenterId      String
  startDate         DateTime
  endDate           DateTime
  sequence          Int      @default(0)
  durationMinutes   Int      @default(0)
  status            String   @default("SCHEDULED") // SCHEDULED | IN_PROGRESS | COMPLETED
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([companyId, workCenterId])
  @@index([productionOrderId])
  @@map("gdr_production_schedules")
}

// ─── Planejamento de Capacidade (S28C) ───────────────────────────────────────

model WorkCenter {
  id                  String   @id @default(cuid())
  companyId           String
  company             Company  @relation(fields: [companyId], references: [id])
  code                String
  name                String
  description         String?
  capacityHoursPerDay Decimal  @default(8) @db.Decimal(5, 2)
  costPerHour         Decimal  @default(0) @db.Decimal(14, 4)
  operatorsCount      Int      @default(1)
  efficiencyPct       Decimal  @default(85) @db.Decimal(5, 2)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([companyId, code])
  @@index([companyId])
  @@map("gdr_work_centers")
}

// ─── Gestão de Lotes (S28D) ──────────────────────────────────────────────────

enum BatchStatus {
  ACTIVE
  QUARANTINE
  CONSUMED
  EXPIRED
  SCRAPPED
}

enum BatchEventType {
  RECEIPT
  TRANSFER
  CONSUMPTION
  ADJUSTMENT
  QUARANTINE
  RELEASE
  EXPIRY
  SCRAP
}

model Batch {
  id                 String      @id @default(cuid())
  companyId          String
  company            Company     @relation(fields: [companyId], references: [id])
  batchNumber        String
  productId          String
  product            Product     @relation("BatchProduct", fields: [productId], references: [id])
  supplierId         String?
  supplier           Supplier?   @relation("BatchSupplier", fields: [supplierId], references: [id])
  goodsReceiptId     String?
  goodsReceipt       GoodsReceipt? @relation(fields: [goodsReceiptId], references: [id])
  status             BatchStatus @default(ACTIVE)
  initialQty         Decimal     @db.Decimal(14, 4)
  currentQty         Decimal     @db.Decimal(14, 4)
  unit               UnitOfMeasure @default(UN)
  manufacturingDate  DateTime?
  expirationDate     DateTime?
  warehouseId        String?
  warehouse          Warehouse?  @relation(fields: [warehouseId], references: [id])
  notes              String?
  events             BatchEvent[]
  serialComponents   SerialComponent[] @relation("SerialComponentBatch")
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@unique([companyId, batchNumber, productId])
  @@index([companyId, status])
  @@index([productId])
  @@index([expirationDate])
  @@map("gdr_batches")
}

model BatchEvent {
  id                  String         @id @default(cuid())
  batchId             String
  batch               Batch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  type                BatchEventType
  quantity            Decimal        @db.Decimal(14, 4)
  qtyBefore           Decimal        @db.Decimal(14, 4)
  qtyAfter            Decimal        @db.Decimal(14, 4)
  productionOrderId   String?
  productionOrder     ProductionOrder? @relation(fields: [productionOrderId], references: [id])
  warehouseFromId     String?
  warehouseTo         String?
  reference           String?
  notes               String?
  userId              String?
  user                User?          @relation("BatchEventUser", fields: [userId], references: [id])
  createdAt           DateTime       @default(now())

  @@index([batchId])
  @@index([productionOrderId])
  @@map("gdr_batch_events")
}
// ─── Categorias Financeiras ──────────────────────────────────────────────────

enum FinancialCategoryType {
  REVENUE
  EXPENSE
  TRANSFER
  GROUP
}

model FinancialCategory {
  id        String                @id @default(cuid())
  companyId String
  company   Company               @relation(fields: [companyId], references: [id])
  code      String?
  name      String
  type      FinancialCategoryType @default(EXPENSE)
  parentId  String?
  parent    FinancialCategory?    @relation("subcategories", fields: [parentId], references: [id])
  children  FinancialCategory[]   @relation("subcategories")
  dreCode   String?
  isActive  Boolean               @default(true)
  legacyId  String?

  entries     FinancialEntry[]
  payables    Payable[]
  receivables Receivable[]
  budgets     Budget[]

  createdAt DateTime @default(now())

  @@unique([companyId, code])
  @@map("gdr_financial_categories")
}

// ─── Centro de Custo ──────────────────────────────────────────────────────────

model CostCenter {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id])
  name      String
  code      String?
  isActive  Boolean @default(true)
  parentId  String?
  parent    CostCenter?  @relation("CostCenterHierarchy", fields: [parentId], references: [id])
  children  CostCenter[] @relation("CostCenterHierarchy")
  legacyId  String?

  payableAllocations    PayableAllocation[]
  receivableAllocations ReceivableAllocation[]
  entrySplits           EntryCostCenterSplit[]

  createdAt DateTime @default(now())

  budgets   Budget[]

  @@index([parentId])
  @@map("gdr_cost_centers")
}

// ─── Orçamento Empresarial (Fase 7, #195) ────────────────────────────────────

model Budget {
  id           String            @id @default(cuid())
  companyId    String
  company      Company           @relation(fields: [companyId], references: [id])
  year         Int
  month        Int               // 1-12
  costCenterId String?
  costCenter   CostCenter?       @relation(fields: [costCenterId], references: [id])
  categoryId   String?
  category     FinancialCategory? @relation(fields: [categoryId], references: [id])
  amount       Decimal           @db.Decimal(14, 4)
  description  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([companyId, year, month, costCenterId, categoryId])
  @@index([companyId, year])
  @@map("gdr_budgets")
}

// ─── Contas a Pagar ───────────────────────────────────────────────────────────

enum PayableStatus {
  OPEN
  PAID
  CANCELLED
  OVERDUE
}

model Payable {
  id              String             @id @default(cuid())
  companyId       String
  company         Company            @relation(fields: [companyId], references: [id])
  supplierId      String?
  supplier        Supplier?          @relation(fields: [supplierId], references: [id])
  categoryId      String?
  category        FinancialCategory? @relation(fields: [categoryId], references: [id])
  bankAccountId   String?
  bankAccount     BankAccount?       @relation(fields: [bankAccountId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id])
  description     String?
  amount          Decimal            @db.Decimal(14, 4)
  dueDate         DateTime
  status          PayableStatus      @default(OPEN)
  paidAt          DateTime?
  paidAmount      Decimal?           @db.Decimal(14, 4)
  origin          String?
  legacyId        String?

  allocations    PayableAllocation[]
  paymentEntries PaymentEntry[]
  commissions    Commission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([dueDate])
  @@map("gdr_payables")
}

model PayableAllocation {
  id           String     @id @default(cuid())
  payableId    String
  payable      Payable    @relation(fields: [payableId], references: [id], onDelete: Cascade)
  costCenterId String
  costCenter   CostCenter @relation(fields: [costCenterId], references: [id])
  percentage   Decimal    @db.Decimal(5, 2)

  @@map("gdr_payable_allocations")
}

model PaymentEntry {
  id        String   @id @default(cuid())
  payableId String
  payable   Payable  @relation(fields: [payableId], references: [id])
  amount    Decimal  @db.Decimal(14, 4)
  paidAt    DateTime
  origin    String?
  legacyId  String?

  createdAt DateTime @default(now())

  @@map("gdr_payment_entries")
}

// ─── Contas a Receber ─────────────────────────────────────────────────────────

enum ReceivableStatus {
  OPEN
  PAID
  CANCELLED
  OVERDUE
}

model Receivable {
  id            String             @id @default(cuid())
  companyId     String
  company       Company            @relation(fields: [companyId], references: [id])
  customerId    String?
  customer      Customer?          @relation(fields: [customerId], references: [id])
  categoryId    String?
  category      FinancialCategory? @relation(fields: [categoryId], references: [id])
  bankAccountId String?
  bankAccount   BankAccount?       @relation(fields: [bankAccountId], references: [id])
  salesOrderId  String?            @unique
  salesOrder    SalesOrder?        @relation(fields: [salesOrderId], references: [id])
  description   String?
  amount        Decimal            @db.Decimal(14, 4)
  dueDate       DateTime
  status        ReceivableStatus   @default(OPEN)
  paidAt        DateTime?
  paidAmount    Decimal?           @db.Decimal(14, 4)
  accessKey     String?
  legacyId      String?

  allocations        ReceivableAllocation[]
  collectionAttempts CollectionAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, status])
  @@index([dueDate])
  @@map("gdr_receivables")
}

model ReceivableAllocation {
  id           String     @id @default(cuid())
  receivableId String
  receivable   Receivable @relation(fields: [receivableId], references: [id], onDelete: Cascade)
  costCenterId String
  costCenter   CostCenter @relation(fields: [costCenterId], references: [id])
  percentage   Decimal    @db.Decimal(5, 2)

  @@map("gdr_receivable_allocations")
}

model ApprovalMatrix {
  id                String   @id @default(cuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id])
  entityType        String
  conditionField    String?
  conditionOp       String?
  conditionValue    String?
  level             Int      @default(1)
  requiredApprovals Int      @default(1)
  approverRoles     String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, entityType])
  @@map("gdr_approval_matrices")
}

// ─── Fase 5: Tabela de Preços (#189) ─────────────────────────────────────────

enum PriceTableType {
  STANDARD
  PROMOTIONAL
  CUSTOMER_SPECIFIC
}

model PriceTable {
  id         String         @id @default(cuid())
  companyId  String
  company    Company        @relation(fields: [companyId], references: [id])
  name       String
  type       PriceTableType @default(STANDARD)
  validFrom  DateTime
  validTo    DateTime?
  isDefault  Boolean        @default(false)
  isActive   Boolean        @default(true)
  customerId  String?
  customer    Customer?      @relation(fields: [customerId], references: [id])
  warehouseId String?
  warehouse   Warehouse?     @relation(fields: [warehouseId], references: [id])
  items       PriceTableItem[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([companyId, isActive])
  @@index([companyId, warehouseId, isActive])
  @@index([customerId])
  @@map("gdr_price_tables")
}

model PriceTableItem {
  id              String     @id @default(cuid())
  priceTableId    String
  priceTable      PriceTable @relation(fields: [priceTableId], references: [id], onDelete: Cascade)
  productId       String
  product         Product    @relation(fields: [productId], references: [id])
  unitPrice       Decimal    @db.Decimal(14, 4)
  minQuantity     Decimal?   @db.Decimal(14, 4)
  discountPercent Decimal?   @db.Decimal(5, 2)

  @@unique([priceTableId, productId, minQuantity])
  @@map("gdr_price_table_items")
}

// ─── Fase 5: Comissões (#191) ────────────────────────────────────────────────

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

model CommissionRule {
  id                String    @id @default(cuid())
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id])
  userId            String
  user              User      @relation("CommissionRuleUser", fields: [userId], references: [id])
  productCategoryId String?
  percentRate       Decimal   @db.Decimal(5, 2)
  fixedAmount       Decimal?  @db.Decimal(14, 4)
  validFrom         DateTime
  validTo           DateTime?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([companyId, userId])
  @@map("gdr_commission_rules")
}

model Commission {
  id           String           @id @default(cuid())
  companyId    String
  company      Company          @relation(fields: [companyId], references: [id])
  userId       String
  user         User             @relation("CommissionUser", fields: [userId], references: [id])
  salesOrderId String
  salesOrder   SalesOrder       @relation(fields: [salesOrderId], references: [id])
  amount       Decimal          @db.Decimal(14, 4)
  status       CommissionStatus @default(PENDING)
  payableId    String?
  payable      Payable?         @relation(fields: [payableId], references: [id])
  calculatedAt DateTime         @default(now())
  approvedAt   DateTime?
  paidAt       DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([companyId, userId])
  @@index([salesOrderId])
  @@map("gdr_commissions")
}

// ─── Fase 5: RFQ — Cotação de Compras (#192) ────────────────────────────────

enum RfqStatus {
  DRAFT
  SENT
  QUOTED
  AWARDED
  CANCELLED
}

model RequestForQuotation {
  id         String    @id @default(cuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id])
  title      String
  status     RfqStatus @default(DRAFT)
  deadline   DateTime?
  notes      String?
  createdById String?
  createdBy  User?     @relation("RfqCreatedBy", fields: [createdById], references: [id])
  items      RfqItem[]
  quotes     RfqQuote[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([companyId, status])
  @@map("gdr_rfqs")
}

model RfqItem {
  id        String              @id @default(cuid())
  rfqId     String
  rfq       RequestForQuotation @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  productId String
  product   Product             @relation(fields: [productId], references: [id])
  quantity  Decimal             @db.Decimal(14, 4)
  specs     String?
  quoteItems RfqQuoteItem[]

  @@map("gdr_rfq_items")
}

model RfqQuote {
  id           String              @id @default(cuid())
  rfqId        String
  rfq          RequestForQuotation @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  supplierId   String
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  totalAmount  Decimal?            @db.Decimal(14, 4)
  deliveryDays Int?
  paymentTerms String?
  validUntil   DateTime?
  isAwarded    Boolean             @default(false)
  purchaseOrderId String?
  purchaseOrder PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id])
  items        RfqQuoteItem[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([rfqId, supplierId])
  @@map("gdr_rfq_quotes")
}

model RfqQuoteItem {
  id         String   @id @default(cuid())
  quoteId    String
  quote      RfqQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  rfqItemId  String
  rfqItem    RfqItem  @relation(fields: [rfqItemId], references: [id])
  unitPrice  Decimal  @db.Decimal(14, 4)
  quantity   Decimal  @db.Decimal(14, 4)

  @@map("gdr_rfq_quote_items")
}
