generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Empresa / Tenant ─────────────────────────────────────────────────────────

enum TaxRegime {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
}

model Company {
  id        String   @id @default(cuid())
  name      String
  cnpj      String   @unique
  type      CompanyType @default(MATRIZ)
  parentId  String?
  parent    Company?  @relation("branches", fields: [parentId], references: [id])
  branches  Company[] @relation("branches")

  // ── Dados fiscais ──
  razaoSocial  String?
  ie           String?   // Inscrição Estadual
  im           String?   // Inscrição Municipal
  crt          Int?      // Código Regime Tributário: 1=SN, 2=SN-ExSub, 3=Normal
  taxRegime    TaxRegime?
  suframa      String?
  cnae         String?   // CNAE principal

  // ── Endereço ──
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?   // UF (2 letras)
  zipCode      String?   // CEP
  ibgeCode     String?   // Código IBGE do município
  phone        String?
  email        String?
  users     User[]
  auditLogs AuditLog[]
  products  Product[]
  suppliers Supplier[]
  customers Customer[]
  bomVersions    BomVersion[]
  routingSteps   RoutingStep[]
  warehouses       Warehouse[]
  stockBalances    StockBalance[]
  stockMovements   StockMovement[]
  purchaseOrders   PurchaseOrder[]
  goodsReceipts    GoodsReceipt[]
  salesOrders      SalesOrder[]
  fiscalDocuments  FiscalDocument[]
  financialEntries     FinancialEntry[]
  bankAccounts         BankAccount[]
  storeTransfers       StoreTransfer[]
  demandForecasts      DemandForecast[]
  purchaseRequests     PurchaseRequest[]
  supplierPriceHistory SupplierPriceHistory[]
  systemParameters     SystemParameter[]
  mrpRuns              MrpRun[]
  productionOrders     ProductionOrder[]
  locations        Location[]
  receivingOrders  ReceivingOrder[]
  putawayTasks     PutawayTask[]
  pickingOrders    PickingOrder[]
  pickTasks        PickTask[]
  inventoryCounts  InventoryCount[]
  inventoryItems   InventoryCountItem[]
  alerts           Alert[]
  inspections      Inspection[]
  nonConformances  NonConformance[]
  serialNumbers    SerialNumber[]
  equipment        Equipment[]
  maintenanceOrders MaintenanceOrder[]
  quotations       Quotation[]
  inboundNfes      InboundNfe[]
  workCenters      WorkCenter[]
  batches          Batch[]
  // Finance
  financialCategories  FinancialCategory[]
  costCenters          CostCenter[]
  payables             Payable[]
  receivables          Receivable[]
  // Banking (S38-S41)
  boletos              Boleto[]
  cnabRemessas         CnabRemessa[]
  cnabRetornos         CnabRetorno[]
  reconciliationItems  ReconciliationItem[]
  ddaMandates          DdaMandate[]
  creditLimits         CreditLimit[]
  pixCharges           PixCharge[]
  fraudRules           FraudRule[]
  fraudAlerts          FraudAlert[]
  // BPM (S34-S37)
  workflows            Workflow[]
  workflowInstances    WorkflowInstance[]
  approvalMatrices     ApprovalMatrix[]
  slaDefinitions       SlaDefinition[]
  taskAssignments      TaskAssignment[]
  emailTemplates       EmailTemplate[]
  notifications        Notification[]
  // Analytics (S30-S33)
  factSalesDaily       FactSalesDaily[]
  factInventoryDaily   FactInventoryDaily[]
  factProductionDaily  FactProductionDaily[]
  factFinancialDaily   FactFinancialDaily[]
  dashboards           Dashboard[]
  alertRules           AlertRule[]
  alertTriggers        AlertTrigger[]
  metricDefinitions    MetricDefinition[]
  dimensionDefinitions DimensionDefinition[]
  reportSchedules      ReportSchedule[]
  analyticsQueryLogs   AnalyticsQueryLog[]
  taxRules             TaxRule[]
  fiscalVoidRanges     FiscalVoidRange[]
  threeWayMatches      ThreeWayMatch[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gdr_companies")
}

enum CompanyType {
  MATRIZ
  FILIAL
}

// ─── Motor Tributário ─────────────────────────────────────────────────────────

enum TaxOperationType {
  VENDA_INTERNA
  VENDA_INTERESTADUAL
  DEVOLUCAO_VENDA
  TRANSFERENCIA_INTERNA
  TRANSFERENCIA_INTERESTADUAL
  COMPRA_INTERNA
  COMPRA_INTERESTADUAL
  DEVOLUCAO_COMPRA
  REMESSA_CONSERTO
  RETORNO_CONSERTO
  AMOSTRA_GRATIS
  BONIFICACAO
  INDUSTRIALIZACAO
}

model TaxRule {
  id               String           @id @default(cuid())
  companyId        String
  company          Company          @relation(fields: [companyId], references: [id])
  operationType    TaxOperationType
  ncm              String?          // Regra por NCM (nullable = regra geral)
  productType      ProductType?     // Regra por tipo de produto (nullable = qualquer)
  ufOrigem         String?          // UF origem (nullable = qualquer)
  ufDestino        String?          // UF destino (nullable = qualquer)
  cfop             String           // Ex: 5101, 6101, 5152
  // ICMS
  icmsCst          String           // Ex: 00, 10, 20, 40, 41, 60
  icmsAliquota     Decimal          @default(0) @db.Decimal(5, 2)
  icmsBaseReducao  Decimal          @default(100) @db.Decimal(5, 2) // % da base (100 = sem redução)
  // IPI
  ipiCst           String           @default("99") // Ex: 00, 49, 50, 99
  ipiAliquota      Decimal          @default(0) @db.Decimal(5, 2)
  // PIS
  pisCst           String           @default("01") // Ex: 01, 06, 07, 49
  pisAliquota      Decimal          @default(0) @db.Decimal(5, 2)
  // COFINS
  cofinsCst        String           @default("01") // Ex: 01, 06, 07, 49
  cofinsAliquota   Decimal          @default(0) @db.Decimal(5, 2)
  // Meta
  description      String?
  priority         Int              @default(0) // Maior = mais específica
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([companyId, operationType, ncm, productType, ufOrigem, ufDestino])
  @@index([companyId, operationType])
  @@map("gdr_tax_rules")
}

// ─── Usuário ──────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          UserRole @default(READER)
  isActive      Boolean  @default(true)
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  stockMovements            StockMovement[]
  createdPurchaseOrders     PurchaseOrder[] @relation("POCreatedBy")
  approvedPurchaseOrders    PurchaseOrder[] @relation("POApprovedBy")
  goodsReceipts             GoodsReceipt[]  @relation("GRReceivedBy")
  createdSalesOrders        SalesOrder[]    @relation("SOCreatedBy")
  requestedTransfers        StoreTransfer[] @relation("TransferRequestedBy")
  dispatchedTransfers       StoreTransfer[] @relation("TransferDispatchedBy")
  receivedTransfers         StoreTransfer[] @relation("TransferReceivedBy")
  demandForecasts           DemandForecast[]    @relation("DemandCreatedBy")
  purchaseRequests          PurchaseRequest[]   @relation("PRRequestedBy")
  triggeredMrpRuns          MrpRun[]            @relation("MrpTriggeredBy")
  createdProductionOrders   ProductionOrder[]   @relation("POProdCreatedBy")
  productionLogs            ProductionLog[]     @relation("ProductionLogUser")
  putawayConfirmations      PutawayTask[]       @relation("PutawayConfirmedBy")
  pickConfirmations         PickTask[]          @relation("PickConfirmedBy")
  inventoryCountsCreated    InventoryCount[]    @relation("InventoryCreatedBy")
  inventoryCountsReconciled InventoryCount[]    @relation("InventoryReconciledBy")
  inventoryItemsCounted     InventoryCountItem[] @relation("InventoryItemCountedBy")
  inspectionsLed            Inspection[]        @relation("InspectionInspectedBy")
  ncrResponsibilities       NonConformance[]    @relation("NcrResponsible")
  ncrsClosed                NonConformance[]    @relation("NcrClosedBy")
  ncrsCreated               NonConformance[]    @relation("NcrCreatedBy")
  maintenanceTasks          MaintenanceOrder[]  @relation("MaintenanceTechnician")
  maintenanceOrdersCreated  MaintenanceOrder[]  @relation("MaintenanceCreatedBy")
  quotationsCreated         Quotation[]         @relation("QuotationCreatedBy")
  inboundNfesImported       InboundNfe[]        @relation("InboundNfeImportedBy")
  batchEvents               BatchEvent[]        @relation("BatchEventUser")
  matchResolutions          ThreeWayMatch[]     @relation("MatchResolvedBy")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("gdr_users")
}

enum UserRole {
  SUPER_ADMIN
  DIRECTOR
  MANAGER
  COMMERCIAL
  PRODUCTION
  QUALITY
  WAREHOUSE
  FINANCIAL
  STORE
  READER
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@map("gdr_refresh_tokens")
}

// ─── Auditoria ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  entity    String
  action    String
  payload   Json?
  createdAt DateTime @default(now())

  @@map("gdr_audit_logs")
}

// ─── Produto ──────────────────────────────────────────────────────────────────

enum ProductType {
  RAW_MATERIAL
  SEMI_FINISHED
  FINISHED_GOOD
  CONSUMABLE
  SERVICE
  COMPONENT
}

enum UnitOfMeasure {
  UN
  KG
  G
  M
  M2
  M3
  L
  PC
  CX
  PR
}

model Product {
  id          String         @id @default(cuid())
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id])
  sku         String
  name        String
  description String?
  type        ProductType
  unit        UnitOfMeasure  @default(UN)
  ncm         String?
  costPrice   Decimal?       @db.Decimal(14, 4)
  salePrice   Decimal?       @db.Decimal(14, 4)
  avgCost     Decimal?       @db.Decimal(14, 4)
  minStock    Decimal        @default(0) @db.Decimal(14, 4)
  isActive    Boolean        @default(true)
  batches        Batch[]       @relation("BatchProduct")
  boms           BomVersion[]  @relation("ProductBoms")
  usedInBoms     BomItem[]     @relation("ComponentOf")
  routingSteps   RoutingStep[] @relation("ProductRouting")
  stockBalances  StockBalance[]
  stockMovements StockMovement[]
  poItems              POItem[]
  grItems              GRItem[]
  saleItems            SaleItem[]
  transferItems        StoreTransferItem[]
  demandForecasts      DemandForecast[]
  purchaseRequests     PurchaseRequest[]
  supplierPriceHistory SupplierPriceHistory[]
  mrpSuggestions            MrpSuggestion[]
  productionOrdersAsProduct ProductionOrder[]   @relation("ProductionOrderProduct")
  productionOrderItems      ProductionOrderItem[] @relation("ProductionOrderComponent")
  putawayTasks              PutawayTask[]        @relation("PutawayProduct")
  pickTasks                 PickTask[]           @relation("PickTaskProduct")
  inventoryItems            InventoryCountItem[] @relation("InventoryItemProduct")
  nonConformances           NonConformance[]     @relation("NcrProduct")
  serialNumbers             SerialNumber[]       @relation("SerialProduct")
  quotationItems            QuotationItem[]      @relation("QuotationItemProduct")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([companyId, sku])
  @@map("gdr_products")
}

// ─── Fornecedor ───────────────────────────────────────────────────────────────

model Supplier {
  id             String          @id @default(cuid())
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id])
  name           String
  cnpj           String?
  email          String?
  phone          String?
  leadTimeDays   Int             @default(0)
  isActive       Boolean         @default(true)
  purchaseOrders       PurchaseOrder[]
  supplierPriceHistory SupplierPriceHistory[]
  nonConformances      NonConformance[]
  portalTokens         SupplierToken[]
  batches              Batch[]               @relation("BatchSupplier")
  payables             Payable[]
  createdAt            DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([companyId, cnpj])
  @@map("gdr_suppliers")
}

// ─── Cliente ──────────────────────────────────────────────────────────────────

enum CustomerType {
  INDIVIDUAL
  COMPANY
}

model Customer {
  id           String       @id @default(cuid())
  companyId    String
  company      Company      @relation(fields: [companyId], references: [id])
  type         CustomerType @default(COMPANY)
  name         String
  document     String?
  email        String?
  phone        String?
  address      String?
  city         String?
  state        String?
  isActive     Boolean      @default(true)
  salesOrders  SalesOrder[]
  quotations   Quotation[]
  receivables  Receivable[]
  ddaMandates  DdaMandate[]
  creditLimits CreditLimit[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([companyId, document])
  @@map("gdr_customers")
}

// ─── BOM — Bill of Materials ──────────────────────────────────────────────────

model BomVersion {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  productId   String
  product     Product   @relation("ProductBoms", fields: [productId], references: [id])
  version     Int
  isActive    Boolean   @default(false)
  notes       String?
  items       BomItem[]
  createdAt   DateTime  @default(now())

  @@unique([productId, version])
  @@map("gdr_bom_versions")
}

model BomItem {
  id           String     @id @default(cuid())
  bomVersionId String
  bomVersion   BomVersion @relation(fields: [bomVersionId], references: [id], onDelete: Cascade)
  componentId  String
  component    Product    @relation("ComponentOf", fields: [componentId], references: [id])
  quantity     Decimal    @db.Decimal(14, 4)
  scrapPct     Decimal    @default(0) @db.Decimal(5, 2)
  unit         UnitOfMeasure @default(UN)

  @@map("gdr_bom_items")
}

// ─── Roteiro de Produção ─────────────────────────────────────────────────────

model RoutingStep {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  productId       String
  product         Product  @relation("ProductRouting", fields: [productId], references: [id])
  stepOrder       Int
  name            String
  workCenter      String?
  setupTimeMin    Int      @default(0)
  runTimeMin      Int      @default(0)
  notes           String?
  productionLogs  ProductionLog[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([productId, stepOrder])
  @@map("gdr_routing_steps")
}

// ─── Estoque ──────────────────────────────────────────────────────────────────

enum MovementType {
  ENTRY
  EXIT
  ADJUSTMENT
  REVERSAL
  TRANSFER_OUT
  TRANSFER_IN
}

model Warehouse {
  id          String          @id @default(cuid())
  companyId   String
  company     Company         @relation(fields: [companyId], references: [id])
  name        String
  code        String
  description String?
  isActive    Boolean         @default(true)
  wmsEnabled       Boolean         @default(false)
  batches          Batch[]
  balances         StockBalance[]
  movements        StockMovement[]
  goodsReceipts    GoodsReceipt[]
  salesOrders      SalesOrder[]
  transfersFrom    StoreTransfer[] @relation("TransferFrom")
  transfersTo      StoreTransfer[] @relation("TransferTo")
  productionOrders ProductionOrder[]
  locations        Location[]
  receivingOrders  ReceivingOrder[]
  pickingOrders    PickingOrder[]
  inventoryCounts  InventoryCount[]
  serialNumbers    SerialNumber[]
  quotations       Quotation[]
  createdAt     DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([companyId, code])
  @@map("gdr_warehouses")
}

model StockBalance {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  available       Decimal   @default(0) @db.Decimal(14, 4)
  reserved        Decimal   @default(0) @db.Decimal(14, 4)
  inTransit       Decimal   @default(0) @db.Decimal(14, 4)
  pendingPutaway  Decimal   @default(0) @db.Decimal(14, 4)
  updatedAt       DateTime  @updatedAt

  @@unique([warehouseId, productId])
  @@map("gdr_stock_balances")
}

model StockMovement {
  id           String       @id @default(cuid())
  companyId    String
  company      Company      @relation(fields: [companyId], references: [id])
  warehouseId  String
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id])
  productId    String
  product      Product      @relation(fields: [productId], references: [id])
  type         MovementType
  quantity     Decimal      @db.Decimal(14, 4)
  reason       String
  reference    String?
  reversedById String?
  userId       String?
  user         User?        @relation(fields: [userId], references: [id])
  createdAt    DateTime     @default(now())

  @@map("gdr_stock_movements")
}

// ─── Compras ──────────────────────────────────────────────────────────────────

enum PurchaseRequestStatus {
  OPEN
  APPROVED
  CONVERTED
  CANCELLED
}

model PurchaseRequest {
  id              String                @id @default(cuid())
  companyId       String
  company         Company               @relation(fields: [companyId], references: [id])
  productId       String
  product         Product               @relation(fields: [productId], references: [id])
  quantity        Decimal               @db.Decimal(14, 4)
  unit            UnitOfMeasure         @default(UN)
  neededBy        DateTime?
  justification   String?
  status          PurchaseRequestStatus @default(OPEN)
  requestedById   String?
  requestedBy     User?                 @relation("PRRequestedBy", fields: [requestedById], references: [id])
  convertedToId   String?
  convertedTo     PurchaseOrder?        @relation("PRConvertedTo", fields: [convertedToId], references: [id])
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([companyId, status])
  @@map("gdr_purchase_requests")
}

model SupplierPriceHistory {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  unitCost    Decimal  @db.Decimal(14, 4)
  goodsReceiptId String?
  recordedAt  DateTime @default(now())

  @@index([supplierId, productId])
  @@index([companyId])
  @@map("gdr_supplier_price_history")
}

enum PurchaseOrderStatus {
  DRAFT
  APPROVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  companyId    String
  company      Company             @relation(fields: [companyId], references: [id])
  supplierId   String
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  status       PurchaseOrderStatus @default(DRAFT)
  expectedAt   DateTime?
  notes        String?
  createdById  String?
  createdBy    User?               @relation("POCreatedBy", fields: [createdById], references: [id])
  approvedById String?
  approvedBy   User?               @relation("POApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  items                POItem[]
  receipts             GoodsReceipt[]
  financialEntries     FinancialEntry[]
  payables             Payable[]
  convertedFromRequests PurchaseRequest[] @relation("PRConvertedTo")
  inboundNfes          InboundNfe[]
  threeWayMatches      ThreeWayMatch[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@map("gdr_purchase_orders")
}

model POItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Decimal       @db.Decimal(14, 4)
  unitCost        Decimal       @db.Decimal(14, 4)
  unit            UnitOfMeasure @default(UN)
  grItems         GRItem[]

  @@map("gdr_po_items")
}

model GoodsReceipt {
  id              String        @id @default(cuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id])
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  warehouseId     String
  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id])
  receivedById    String?
  receivedBy      User?         @relation("GRReceivedBy", fields: [receivedById], references: [id])
  notes            String?
  items            GRItem[]
  batches          Batch[]
  financialEntry   FinancialEntry?
  receivingOrder   ReceivingOrder?
  inspections      Inspection[]
  inboundNfe       InboundNfe?
  threeWayMatches  ThreeWayMatch[]
  createdAt        DateTime      @default(now())

  @@map("gdr_goods_receipts")
}

model GRItem {
  id               String       @id @default(cuid())
  goodsReceiptId   String
  goodsReceipt     GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  poItemId         String
  poItem           POItem       @relation(fields: [poItemId], references: [id])
  productId        String
  product          Product      @relation(fields: [productId], references: [id])
  qtyOrdered       Decimal      @db.Decimal(14, 4)
  qtyReceived      Decimal      @db.Decimal(14, 4)
  divergenceReason String?

  @@map("gdr_gr_items")
}

// ─── 3-Way Match ──────────────────────────────────────────────────────────────

enum ThreeWayMatchResult {
  FULL_MATCH
  PARTIAL_MATCH
  MISMATCH
}

model ThreeWayMatch {
  id              String              @id @default(cuid())
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id])
  purchaseOrderId String
  purchaseOrder   PurchaseOrder       @relation(fields: [purchaseOrderId], references: [id])
  goodsReceiptId  String
  goodsReceipt    GoodsReceipt        @relation(fields: [goodsReceiptId], references: [id])
  inboundNfeId    String?
  inboundNfe      InboundNfe?         @relation(fields: [inboundNfeId], references: [id])
  result          ThreeWayMatchResult
  qtyTolerance    Decimal             @default(0) @db.Decimal(5, 2)
  priceTolerance  Decimal             @default(2) @db.Decimal(5, 2)
  details         Json                // Array of per-item match details
  resolvedById    String?
  resolvedBy      User?               @relation("MatchResolvedBy", fields: [resolvedById], references: [id])
  resolvedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([companyId, result])
  @@index([purchaseOrderId])
  @@map("gdr_three_way_matches")
}

// ─── Vendas ───────────────────────────────────────────────────────────────────

enum SalesOrderStatus {
  DRAFT
  RESERVED
  CONFIRMED
  AWAITING_PICKING
  READY_TO_INVOICE
  INVOICED
  RETURNED
  CANCELLED
}

model SalesOrder {
  id          String           @id @default(cuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id])
  customerId  String?
  customer    Customer?        @relation(fields: [customerId], references: [id])
  warehouseId String
  warehouse   Warehouse        @relation(fields: [warehouseId], references: [id])
  status      SalesOrderStatus @default(DRAFT)
  notes       String?
  createdById String?
  createdBy   User?            @relation("SOCreatedBy", fields: [createdById], references: [id])
  confirmedAt DateTime?
  pickedAt    DateTime?
  invoicedAt  DateTime?
  returnedAt  DateTime?
  cancelledAt DateTime?
  items            SaleItem[]
  fiscalDocument   FiscalDocument?
  financialEntry   FinancialEntry?
  pickingOrder     PickingOrder?
  serialNumbers    SerialNumber[]
  quotation        Quotation?
  receivable       Receivable?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("gdr_sales_orders")
}

model SaleItem {
  id           String        @id @default(cuid())
  salesOrderId String
  salesOrder   SalesOrder    @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product       @relation(fields: [productId], references: [id])
  quantity     Decimal       @db.Decimal(14, 4)
  unitPrice    Decimal       @db.Decimal(14, 4)
  unit         UnitOfMeasure @default(UN)

  @@map("gdr_sale_items")
}

// ─── Fiscal ───────────────────────────────────────────────────────────────────

enum FiscalDocumentType {
  NFE
  NFCE
}

enum FiscalStatus {
  PENDING
  PROCESSING
  AUTHORIZED
  REJECTED
  CANCELLED
  ERROR
}

model FiscalDocument {
  id               String             @id @default(cuid())
  companyId        String
  company          Company            @relation(fields: [companyId], references: [id])
  salesOrderId     String?            @unique
  salesOrder       SalesOrder?        @relation(fields: [salesOrderId], references: [id])
  storeTransferId  String?            @unique
  storeTransfer    StoreTransfer?     @relation(fields: [storeTransferId], references: [id])
  type             FiscalDocumentType @default(NFCE)
  status           FiscalStatus       @default(PENDING)
  focusRef         String?
  chave            String?
  xml              String?
  rejectionCode    String?
  rejectionReason  String?
  retryCount       Int                @default(0)
  lastError        String?
  cancelledAt              DateTime?
  cancellationJustification String?
  financialEntry   FinancialEntry?
  items            FiscalDocumentItem[]
  corrections      FiscalCorrection[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@map("gdr_fiscal_documents")
}

model FiscalCorrection {
  id               String         @id @default(cuid())
  fiscalDocumentId String
  fiscalDocument   FiscalDocument @relation(fields: [fiscalDocumentId], references: [id])
  sequenceNumber   Int            // 1 a 20 (máximo SEFAZ)
  correctionText   String
  protocol         String?        // protocolo retornado pela SEFAZ
  createdAt        DateTime       @default(now())

  @@unique([fiscalDocumentId, sequenceNumber])
  @@index([fiscalDocumentId])
  @@map("gdr_fiscal_corrections")
}

model FiscalVoidRange {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  serie         String   // série da NF-e (ex: "1")
  numberStart   Int      // número inicial
  numberEnd     Int      // número final
  justification String
  protocol      String?  // protocolo retornado pela SEFAZ
  year          Int      // ano fiscal
  createdAt     DateTime @default(now())

  @@index([companyId])
  @@map("gdr_fiscal_void_ranges")
}

model FiscalDocumentItem {
  id               String         @id @default(cuid())
  fiscalDocumentId String
  fiscalDocument   FiscalDocument @relation(fields: [fiscalDocumentId], references: [id], onDelete: Cascade)
  productId        String?
  productCode      String?
  productName      String
  ncm              String?
  cest             String?        // Código Especificador de Substituição Tributária
  cfop             String?
  unit             String?
  quantity         Decimal        @db.Decimal(14, 4)
  unitPrice        Decimal        @db.Decimal(14, 4)
  totalPrice       Decimal        @db.Decimal(14, 4)
  legacyId         String?
  taxes            FiscalDocumentItemTax[]

  @@index([fiscalDocumentId])
  @@map("gdr_fiscal_document_items")
}

model FiscalDocumentItemTax {
  id                   String             @id @default(cuid())
  fiscalDocumentItemId String
  fiscalDocumentItem   FiscalDocumentItem @relation(fields: [fiscalDocumentItemId], references: [id], onDelete: Cascade)
  cstIcms              String?
  baseIcms             Decimal?           @db.Decimal(14, 4)
  aliquotaIcms         Decimal?           @db.Decimal(14, 4)
  valorIcms            Decimal?           @db.Decimal(14, 4)
  cstIpi               String?
  baseIpi              Decimal?           @db.Decimal(14, 4)
  aliquotaIpi          Decimal?           @db.Decimal(14, 4)
  valorIpi             Decimal?           @db.Decimal(14, 4)
  cstPis               String?
  basePis              Decimal?           @db.Decimal(14, 4)
  aliquotaPis          Decimal?           @db.Decimal(14, 4)
  valorPis             Decimal?           @db.Decimal(14, 4)
  cstCofins            String?
  baseCofins           Decimal?           @db.Decimal(14, 4)
  aliquotaCofins       Decimal?           @db.Decimal(14, 4)
  valorCofins          Decimal?           @db.Decimal(14, 4)

  @@map("gdr_fiscal_document_item_taxes")
}

// ─── Financeiro ───────────────────────────────────────────────────────────────

enum FinancialEntryType {
  RECEIVABLE
  PAYABLE
}

enum FinancialEntryStatus {
  OPEN
  OVERDUE
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum PaymentMethod {
  BOLETO
  PIX
  TED
  DINHEIRO
  CARTAO
  CHEQUE
}

enum EntrySource {
  AUTO_SALES
  AUTO_PURCHASE
  MANUAL
}

model FinancialEntry {
  id               String               @id @default(cuid())
  companyId        String
  company          Company              @relation(fields: [companyId], references: [id])
  type             FinancialEntryType
  status           FinancialEntryStatus @default(OPEN)
  amount           Decimal              @db.Decimal(14, 4)
  dueDate          DateTime
  description      String?
  source           EntrySource          @default(AUTO_SALES)
  attachmentUrl    String?
  salesOrderId     String?              @unique
  salesOrder       SalesOrder?          @relation(fields: [salesOrderId], references: [id])
  purchaseOrderId  String?
  purchaseOrder    PurchaseOrder?       @relation(fields: [purchaseOrderId], references: [id])
  goodsReceiptId   String?              @unique
  goodsReceipt     GoodsReceipt?        @relation(fields: [goodsReceiptId], references: [id])
  fiscalDocumentId String?              @unique
  fiscalDocument   FiscalDocument?      @relation(fields: [fiscalDocumentId], references: [id])
  categoryId       String?
  category         FinancialCategory?   @relation(fields: [categoryId], references: [id])
  paidAt           DateTime?
  paidAmount       Decimal?             @db.Decimal(14, 4)
  paymentNote      String?
  parentEntryId    String?
  parentEntry      FinancialEntry?      @relation("Installments", fields: [parentEntryId], references: [id])
  installments     FinancialEntry[]     @relation("Installments")
  payments         Payment[]
  costCenterSplits EntryCostCenterSplit[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([companyId])
  @@index([type, status])
  @@index([dueDate])
  @@index([parentEntryId])
  @@map("gdr_financial_entries")
}

model Payment {
  id               String             @id @default(cuid())
  financialEntryId String
  financialEntry   FinancialEntry     @relation(fields: [financialEntryId], references: [id])
  amount           Decimal            @db.Decimal(14, 4)
  paidAt           DateTime
  method           PaymentMethod
  bankAccountId    String?
  bankAccount      BankAccount?       @relation(fields: [bankAccountId], references: [id])
  reference        String?
  createdAt        DateTime           @default(now())

  @@index([financialEntryId])
  @@index([bankAccountId])
  @@map("gdr_payments")
}

model EntryCostCenterSplit {
  id           String         @id @default(cuid())
  entryId      String
  entry        FinancialEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  costCenterId String
  costCenter   CostCenter     @relation(fields: [costCenterId], references: [id])
  percentage   Decimal        @db.Decimal(5, 2)
  amount       Decimal        @db.Decimal(14, 4)
  legacyId     String?

  @@index([entryId])
  @@map("gdr_entry_cost_center_splits")
}

model BankAccount {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id])
  name      String
  bank      String?
  agency    String?
  account   String?
  balance   Decimal   @default(0) @db.Decimal(14, 4)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  payments            Payment[]
  payables            Payable[]
  receivables         Receivable[]
  boletos             Boleto[]
  cnabRemessas        CnabRemessa[]
  cnabRetornos        CnabRetorno[]
  reconciliationItems ReconciliationItem[]
  ddaMandates         DdaMandate[]
  pixCharges          PixCharge[]
  fraudRules          FraudRule[]
  fraudAlerts         FraudAlert[]

  @@index([companyId])
  @@map("gdr_bank_accounts")
}

// ─── Transferências fábrica → loja ───────────────────────────────────────────

enum TransferStatus {
  DRAFT
  DISPATCHED
  RECEIVED
  CANCELLED
}

model StoreTransfer {
  id              String         @id @default(cuid())
  companyId       String
  company         Company        @relation(fields: [companyId], references: [id])
  fromWarehouseId String
  fromWarehouse   Warehouse      @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String
  toWarehouse     Warehouse      @relation("TransferTo", fields: [toWarehouseId], references: [id])
  status          TransferStatus @default(DRAFT)
  notes           String?
  requestedById   String?
  requestedBy     User?          @relation("TransferRequestedBy", fields: [requestedById], references: [id])
  dispatchedById  String?
  dispatchedBy    User?          @relation("TransferDispatchedBy", fields: [dispatchedById], references: [id])
  dispatchedAt    DateTime?
  receivedById    String?
  receivedBy      User?          @relation("TransferReceivedBy", fields: [receivedById], references: [id])
  receivedAt      DateTime?
  cancelledAt     DateTime?
  items           StoreTransferItem[]
  fiscalDocument  FiscalDocument?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([companyId])
  @@index([status])
  @@map("gdr_store_transfers")
}

model StoreTransferItem {
  id              String        @id @default(cuid())
  storeTransferId String
  storeTransfer   StoreTransfer @relation(fields: [storeTransferId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  quantity        Decimal       @db.Decimal(14, 4)
  unit            UnitOfMeasure @default(UN)

  @@map("gdr_store_transfer_items")
}

// ─── Configurações do Sistema ─────────────────────────────────────────────────

model SystemParameter {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, key])
  @@map("gdr_system_parameters")
}

// ─── MRP Engine ──────────────────────────────────────────────────────────────

enum MrpRunStatus {
  RUNNING
  DONE
  ERROR
}

enum MrpSuggestionType {
  PURCHASE
  PRODUCTION
}

model MrpRun {
  id           String        @id @default(cuid())
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id])
  horizonDays  Int
  status       MrpRunStatus  @default(RUNNING)
  errorMessage String?
  suggestions  MrpSuggestion[]
  triggeredById String?
  triggeredBy   User?        @relation("MrpTriggeredBy", fields: [triggeredById], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([companyId])
  @@map("gdr_mrp_runs")
}

model MrpSuggestion {
  id            String             @id @default(cuid())
  mrpRunId      String
  mrpRun        MrpRun             @relation(fields: [mrpRunId], references: [id], onDelete: Cascade)
  productId     String
  product       Product            @relation(fields: [productId], references: [id])
  type          MrpSuggestionType
  grossQty      Decimal            @db.Decimal(14, 4)  // demanda bruta do período
  stockOnHand   Decimal            @db.Decimal(14, 4)  // estoque disponível atual
  netQty        Decimal            @db.Decimal(14, 4)  // necessidade líquida (gross - stock)
  bomLevel      Int                @default(0)         // 0=produto final, 1+=componente
  suggestedDate DateTime?
  notes         String?
  createdAt     DateTime           @default(now())

  @@index([mrpRunId])
  @@index([productId])
  @@map("gdr_mrp_suggestions")
  productionOrders ProductionOrder[]
}

// ─── Ordens de Produção ───────────────────────────────────────────────────────

enum ProductionOrderStatus {
  DRAFT
  RELEASED
  IN_PROGRESS
  DONE
  CANCELLED
}

model ProductionLog {
  id                String          @id @default(cuid())
  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  routingStepId     String?
  routingStep       RoutingStep?    @relation(fields: [routingStepId], references: [id])
  stepOrder         Int?            // cache do stepOrder para ordenação
  workCenter        String?
  qty               Decimal         @db.Decimal(14, 4)
  userId            String?
  user              User?           @relation("ProductionLogUser", fields: [userId], references: [id])
  notes             String?
  loggedAt          DateTime        @default(now()) @map("logged_at")

  @@index([productionOrderId])
  @@map("gdr_production_log")
}

model ProductionOrder {
  id               String                @id @default(cuid())
  companyId        String
  company          Company               @relation(fields: [companyId], references: [id])
  productId        String
  product          Product               @relation("ProductionOrderProduct", fields: [productId], references: [id])
  warehouseId      String
  warehouse        Warehouse             @relation(fields: [warehouseId], references: [id])
  mrpSuggestionId  String?
  mrpSuggestion    MrpSuggestion?        @relation(fields: [mrpSuggestionId], references: [id])
  plannedQty       Decimal               @db.Decimal(14, 4)
  producedQty      Decimal               @default(0) @db.Decimal(14, 4)
  status           ProductionOrderStatus @default(DRAFT)
  scheduledStart   DateTime?
  scheduledEnd     DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  notes            String?
  items            ProductionOrderItem[]
  logs             ProductionLog[]
  cost             ProductionCost?
  inspections      Inspection[]
  serialNumbers    SerialNumber[]
  batchEvents      BatchEvent[]
  createdById      String?
  createdBy        User?                 @relation("POProdCreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([companyId, status])
  @@map("gdr_production_orders")
}

model ProductionCost {
  id                String          @id @default(cuid())
  productionOrderId String          @unique
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  materialCost      Decimal         @default(0) @db.Decimal(14, 4)
  laborCost         Decimal         @default(0) @db.Decimal(14, 4)
  totalCost         Decimal         @default(0) @db.Decimal(14, 4)
  costPerUnit       Decimal         @default(0) @db.Decimal(14, 4)
  breakdown         Json            @default("[]")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("gdr_production_costs")
}

model ProductionOrderItem {
  id                String          @id @default(cuid())
  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  componentId       String
  component         Product         @relation("ProductionOrderComponent", fields: [componentId], references: [id])
  plannedQty        Decimal         @db.Decimal(14, 4)
  consumedQty       Decimal         @default(0) @db.Decimal(14, 4)
  unit              UnitOfMeasure   @default(UN)

  @@map("gdr_production_order_items")
}

// ─── WMS ─────────────────────────────────────────────────────────────────────

enum LocationType {
  RECEIVING
  STORAGE
  STAGING
}

enum ReceivingStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum PutawayStatus {
  PENDING
  CONFIRMED
}

model Location {
  id          String       @id @default(cuid())
  companyId   String
  company     Company      @relation(fields: [companyId], references: [id])
  warehouseId String
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id])
  code        String
  description String?
  type        LocationType @default(STORAGE)
  isActive    Boolean      @default(true)
  putawayTasks PutawayTask[]
  pickTasks    PickTask[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([warehouseId, code])
  @@index([companyId])
  @@map("gdr_locations")
}

model ReceivingOrder {
  id             String          @id @default(cuid())
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id])
  goodsReceiptId String          @unique
  goodsReceipt   GoodsReceipt    @relation(fields: [goodsReceiptId], references: [id])
  warehouseId    String
  warehouse      Warehouse       @relation(fields: [warehouseId], references: [id])
  status         ReceivingStatus @default(PENDING)
  tasks          PutawayTask[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([companyId, status])
  @@map("gdr_receiving_orders")
}

model PutawayTask {
  id               String         @id @default(cuid())
  companyId        String
  company          Company        @relation(fields: [companyId], references: [id])
  receivingOrderId String
  receivingOrder   ReceivingOrder @relation(fields: [receivingOrderId], references: [id], onDelete: Cascade)
  productId        String
  product          Product        @relation("PutawayProduct", fields: [productId], references: [id])
  qty              Decimal        @db.Decimal(14, 4)
  locationId       String?
  location         Location?      @relation(fields: [locationId], references: [id])
  status           PutawayStatus  @default(PENDING)
  confirmedById    String?
  confirmedBy      User?          @relation("PutawayConfirmedBy", fields: [confirmedById], references: [id])
  confirmedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([receivingOrderId])
  @@index([companyId, status])
  @@map("gdr_putaway_tasks")
}

// ─── WMS Saída ────────────────────────────────────────────────────────────────

enum PickingStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum PickTaskStatus {
  PENDING
  CONFIRMED
}

model PickingOrder {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])
  salesOrderId  String        @unique
  salesOrder    SalesOrder    @relation(fields: [salesOrderId], references: [id])
  warehouseId   String
  warehouse     Warehouse     @relation(fields: [warehouseId], references: [id])
  status        PickingStatus @default(PENDING)
  tasks         PickTask[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([companyId, status])
  @@map("gdr_picking_orders")
}

model PickTask {
  id             String         @id @default(cuid())
  companyId      String
  company        Company        @relation(fields: [companyId], references: [id])
  pickingOrderId String
  pickingOrder   PickingOrder   @relation(fields: [pickingOrderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product        @relation("PickTaskProduct", fields: [productId], references: [id])
  qty            Decimal        @db.Decimal(14, 4)
  locationId     String?
  location       Location?      @relation(fields: [locationId], references: [id])
  notes          String?
  status         PickTaskStatus @default(PENDING)
  confirmedById  String?
  confirmedBy    User?          @relation("PickConfirmedBy", fields: [confirmedById], references: [id])
  confirmedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([pickingOrderId])
  @@index([companyId, status])
  @@map("gdr_pick_tasks")
}

// ─── WMS Inventário ───────────────────────────────────────────────────────────

enum InventoryCountType {
  CYCLIC
  FULL
}

enum InventoryCountStatus {
  DRAFT
  IN_PROGRESS
  RECONCILED
  CANCELLED
}

enum InventoryItemStatus {
  PENDING
  COUNTED
}

model InventoryCount {
  id             String               @id @default(cuid())
  companyId      String
  company        Company              @relation(fields: [companyId], references: [id])
  warehouseId    String
  warehouse      Warehouse            @relation(fields: [warehouseId], references: [id])
  type           InventoryCountType   @default(CYCLIC)
  status         InventoryCountStatus @default(DRAFT)
  notes          String?
  createdById    String?
  createdBy      User?                @relation("InventoryCreatedBy", fields: [createdById], references: [id])
  reconciledById String?
  reconciledBy   User?                @relation("InventoryReconciledBy", fields: [reconciledById], references: [id])
  reconciledAt   DateTime?
  items          InventoryCountItem[]
