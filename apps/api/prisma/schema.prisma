generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Empresa / Tenant ─────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String
  cnpj      String   @unique
  type      CompanyType @default(MATRIZ)
  parentId  String?
  parent    Company?  @relation("branches", fields: [parentId], references: [id])
  branches  Company[] @relation("branches")
  users     User[]
  auditLogs AuditLog[]
  products  Product[]
  suppliers Supplier[]
  customers Customer[]
  bomVersions   BomVersion[]
  routingSteps  RoutingStep[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("companies")
}

enum CompanyType {
  MATRIZ
  FILIAL
}

// ─── Usuário ──────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          UserRole @default(READER)
  isActive      Boolean  @default(true)
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  DIRECTOR
  MANAGER
  COMMERCIAL
  PRODUCTION
  QUALITY
  WAREHOUSE
  FINANCIAL
  STORE
  READER
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ─── Auditoria ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  entity    String
  action    String
  payload   Json?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

// ─── Produto ──────────────────────────────────────────────────────────────────

enum ProductType {
  RAW_MATERIAL
  SEMI_FINISHED
  FINISHED_GOOD
  CONSUMABLE
  SERVICE
}

enum UnitOfMeasure {
  UN
  KG
  G
  M
  M2
  M3
  L
  PC
  CX
  PR
}

model Product {
  id          String         @id @default(cuid())
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id])
  sku         String
  name        String
  description String?
  type        ProductType
  unit        UnitOfMeasure  @default(UN)
  ncm         String?
  costPrice   Decimal?       @db.Decimal(14, 4)
  salePrice   Decimal?       @db.Decimal(14, 4)
  isActive    Boolean        @default(true)
  boms          BomVersion[]  @relation("ProductBoms")
  usedInBoms    BomItem[]     @relation("ComponentOf")
  routingSteps  RoutingStep[] @relation("ProductRouting")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([companyId, sku])
  @@map("products")
}

// ─── Fornecedor ───────────────────────────────────────────────────────────────

model Supplier {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  name         String
  cnpj         String?
  email        String?
  phone        String?
  leadTimeDays Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([companyId, cnpj])
  @@map("suppliers")
}

// ─── Cliente ──────────────────────────────────────────────────────────────────

enum CustomerType {
  INDIVIDUAL
  COMPANY
}

model Customer {
  id           String       @id @default(cuid())
  companyId    String
  company      Company      @relation(fields: [companyId], references: [id])
  type         CustomerType @default(COMPANY)
  name         String
  document     String?
  email        String?
  phone        String?
  address      String?
  city         String?
  state        String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([companyId, document])
  @@map("customers")
}

// ─── BOM — Bill of Materials ──────────────────────────────────────────────────

model BomVersion {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  productId   String
  product     Product   @relation("ProductBoms", fields: [productId], references: [id])
  version     Int
  isActive    Boolean   @default(false)
  notes       String?
  items       BomItem[]
  createdAt   DateTime  @default(now())

  @@unique([productId, version])
  @@map("bom_versions")
}

model BomItem {
  id           String     @id @default(cuid())
  bomVersionId String
  bomVersion   BomVersion @relation(fields: [bomVersionId], references: [id], onDelete: Cascade)
  componentId  String
  component    Product    @relation("ComponentOf", fields: [componentId], references: [id])
  quantity     Decimal    @db.Decimal(14, 4)
  scrapPct     Decimal    @default(0) @db.Decimal(5, 2)
  unit         UnitOfMeasure @default(UN)

  @@map("bom_items")
}

// ─── Roteiro de Produção ─────────────────────────────────────────────────────

model RoutingStep {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  productId       String
  product         Product  @relation("ProductRouting", fields: [productId], references: [id])
  stepOrder       Int
  name            String
  workCenter      String?
  setupTimeMin    Int      @default(0)
  runTimeMin      Int      @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([productId, stepOrder])
  @@map("routing_steps")
}
