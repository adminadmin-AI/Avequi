generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Empresa / Tenant ─────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String
  cnpj      String   @unique
  type      CompanyType @default(MATRIZ)
  parentId  String?
  parent    Company?  @relation("branches", fields: [parentId], references: [id])
  branches  Company[] @relation("branches")
  users     User[]
  auditLogs AuditLog[]
  products  Product[]
  suppliers Supplier[]
  customers Customer[]
  bomVersions   BomVersion[]
  routingSteps  RoutingStep[]
  warehouses    Warehouse[]
  stockBalances StockBalance[]
  stockMovements StockMovement[]
  systemParameters SystemParameter[]
  supplierPrices   SupplierPrice[]
  purchaseOrders   PurchaseOrder[]
  goodsReceipts    GoodsReceipt[]
  salesOrders      SalesOrder[]
  fiscalDocuments  FiscalDocument[]
  bankAccounts     BankAccount[]
  financialCategories FinancialCategory[]
  costCenters      CostCenter[]
  payables         Payable[]
  paymentEntries   PaymentEntry[]
  receivables      Receivable[]
  stockTransfers   StockTransfer[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("companies")
}

enum CompanyType {
  MATRIZ
  FILIAL
}

// ─── Usuário ──────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          UserRole @default(READER)
  isActive      Boolean  @default(true)
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  refreshTokens    RefreshToken[]
  auditLogs        AuditLog[]
  stockMovements   StockMovement[]
  purchaseOrdersCreated PurchaseOrder[] @relation("POCreatedBy")
  goodsReceiptsReceived GoodsReceipt[]  @relation("GRReceivedBy")
  salesOrdersCreated    SalesOrder[]    @relation("SOCreatedBy")
  stockTransfersCreated StockTransfer[] @relation("TransferCreatedBy")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  DIRECTOR
  MANAGER
  COMMERCIAL
  PRODUCTION
  QUALITY
  WAREHOUSE
  FINANCIAL
  STORE
  READER
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ─── Auditoria ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  entity    String
  action    String
  payload   Json?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

// ─── Produto ──────────────────────────────────────────────────────────────────

enum ProductType {
  RAW_MATERIAL
  SEMI_FINISHED
  FINISHED_GOOD
  CONSUMABLE
  SERVICE
}

enum UnitOfMeasure {
  UN
  KG
  G
  M
  M2
  M3
  L
  PC
  CX
  PR
}

model Product {
  id          String         @id @default(cuid())
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id])
  sku         String
  name        String
  description String?
  type        ProductType
  unit        UnitOfMeasure  @default(UN)
  ncm         String?
  costPrice   Decimal?       @db.Decimal(14, 4)
  salePrice   Decimal?       @db.Decimal(14, 4)
  isActive    Boolean        @default(true)
  boms              BomVersion[]      @relation("ProductBoms")
  usedInBoms        BomItem[]         @relation("ComponentOf")
  routingSteps      RoutingStep[]     @relation("ProductRouting")
  stockBalances     StockBalance[]
  stockMovements    StockMovement[]
  supplierPrices    SupplierPrice[]
  purchaseOrderItems PurchaseOrderItem[] @relation("POItems")
  goodsReceiptItems  GoodsReceiptItem[]  @relation("GRItems")
  salesOrderItems    SalesOrderItem[]    @relation("SOItems")
  salesOrderSerials  SalesOrderSerial[]  @relation("SOSerials")
  fiscalDocumentItems FiscalDocumentItem[] @relation("FDItems")
  stockTransferItems  StockTransferItem[]  @relation("TransferItems")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([companyId, sku])
  @@map("products")
}

// ─── Fornecedor ───────────────────────────────────────────────────────────────

model Supplier {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  name         String
  cnpj         String?
  email        String?
  phone        String?
  leadTimeDays   Int             @default(0)
  isActive       Boolean         @default(true)
  legacyId       String?
  prices         SupplierPrice[]
  purchaseOrders PurchaseOrder[]
  payables       Payable[]       @relation("PayableSupplier")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([companyId, cnpj])
  @@map("suppliers")
}

// ─── Cliente ──────────────────────────────────────────────────────────────────

enum CustomerType {
  INDIVIDUAL
  COMPANY
}

model Customer {
  id           String       @id @default(cuid())
  companyId    String
  company      Company      @relation(fields: [companyId], references: [id])
  type         CustomerType @default(COMPANY)
  name         String
  document     String?
  email        String?
  phone        String?
  address      String?
  city         String?
  state        String?
  isActive     Boolean      @default(true)
  legacyId     String?
  salesOrders  SalesOrder[]
  receivables  Receivable[] @relation("ReceivableCustomer")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([companyId, document])
  @@map("customers")
}

// ─── BOM — Bill of Materials ──────────────────────────────────────────────────

model BomVersion {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  productId   String
  product     Product   @relation("ProductBoms", fields: [productId], references: [id])
  version     Int
  isActive    Boolean   @default(false)
  notes       String?
  items       BomItem[]
  createdAt   DateTime  @default(now())

  @@unique([productId, version])
  @@map("bom_versions")
}

model BomItem {
  id           String     @id @default(cuid())
  bomVersionId String
  bomVersion   BomVersion @relation(fields: [bomVersionId], references: [id], onDelete: Cascade)
  componentId  String
  component    Product    @relation("ComponentOf", fields: [componentId], references: [id])
  quantity     Decimal    @db.Decimal(14, 4)
  scrapPct     Decimal    @default(0) @db.Decimal(5, 2)
  unit         UnitOfMeasure @default(UN)

  @@map("bom_items")
}

// ─── Roteiro de Produção ─────────────────────────────────────────────────────

model RoutingStep {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  productId       String
  product         Product  @relation("ProductRouting", fields: [productId], references: [id])
  stepOrder       Int
  name            String
  workCenter      String?
  setupTimeMin    Int      @default(0)
  runTimeMin      Int      @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([productId, stepOrder])
  @@map("routing_steps")
}

// ─── Estoque ──────────────────────────────────────────────────────────────────

enum MovementType {
  ENTRY
  EXIT
  ADJUSTMENT
  REVERSAL
  TRANSFER_OUT
  TRANSFER_IN
}

model Warehouse {
  id          String          @id @default(cuid())
  companyId   String
  company     Company         @relation(fields: [companyId], references: [id])
  name        String
  code        String
  description String?
  isActive        Boolean         @default(true)
  balances        StockBalance[]
  movements       StockMovement[]
  goodsReceipts   GoodsReceipt[]
  transfersFrom   StockTransfer[] @relation("TransferFrom")
  transfersTo     StockTransfer[] @relation("TransferTo")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([companyId, code])
  @@map("warehouses")
}

model StockBalance {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id])
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  available   Decimal   @default(0) @db.Decimal(14, 4)
  reserved    Decimal   @default(0) @db.Decimal(14, 4)
  updatedAt   DateTime  @updatedAt

  @@unique([warehouseId, productId])
  @@map("stock_balances")
}

model StockMovement {
  id           String       @id @default(cuid())
  companyId    String
  company      Company      @relation(fields: [companyId], references: [id])
  warehouseId  String
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id])
  productId    String
  product      Product      @relation(fields: [productId], references: [id])
  type         MovementType
  quantity     Decimal      @db.Decimal(14, 4)
  reason       String
  reference    String?
  reversedById String?
  userId       String?
  user         User?        @relation(fields: [userId], references: [id])
  // Origem do movimento (compras, vendas, transferência, etc.)
  sourceType   String?      // PURCHASE_RECEIPT | SALES_ORDER | TRANSFER | PRODUCTION | MANUAL
  sourceId     String?
  createdAt    DateTime     @default(now())

  @@map("stock_movements")
}

// ─── Parâmetro de Sistema ─────────────────────────────────────────────────────

model SystemParameter {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, key])
  @@map("system_parameters")
}

// ─── Preço de Fornecedor ──────────────────────────────────────────────────────

model SupplierPrice {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  price       Decimal  @db.Decimal(14, 4)
  minQty      Decimal  @default(1) @db.Decimal(14, 4)
  leadTimeDays Int     @default(0)
  isActive    Boolean  @default(true)
  validFrom   DateTime @default(now())
  validTo     DateTime?
  legacyId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("supplier_prices")
}

// ─── Compras ──────────────────────────────────────────────────────────────────

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  companyId    String
  company      Company             @relation(fields: [companyId], references: [id])
  supplierId   String
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  number       String
  status       PurchaseOrderStatus @default(DRAFT)
  expectedAt   DateTime?
  notes        String?
  totalAmount  Decimal             @default(0) @db.Decimal(14, 2)
  items        PurchaseOrderItem[]
  receipts     GoodsReceipt[]
  legacyId     String?
  createdById  String?
  createdBy    User?               @relation("POCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([companyId, number])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation("POItems", fields: [productId], references: [id])
  quantity        Decimal       @db.Decimal(14, 4)
  unitPrice       Decimal       @db.Decimal(14, 4)
  totalPrice      Decimal       @db.Decimal(14, 2)
  receivedQty     Decimal       @default(0) @db.Decimal(14, 4)
  unit            UnitOfMeasure @default(UN)

  @@map("purchase_order_items")
}

enum GoodsReceiptStatus {
  PENDING
  INSPECTING
  APPROVED
  REJECTED
}

model GoodsReceipt {
  id              String             @id @default(cuid())
  companyId       String
  company         Company            @relation(fields: [companyId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id])
  warehouseId     String
  warehouse       Warehouse          @relation(fields: [warehouseId], references: [id])
  status          GoodsReceiptStatus @default(PENDING)
  supplierNfeKey  String?
  receivedAt      DateTime           @default(now())
  notes           String?
  items           GoodsReceiptItem[]
  legacyId        String?
  receivedById    String?
  receivedBy      User?              @relation("GRReceivedBy", fields: [receivedById], references: [id])
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@map("goods_receipts")
}

model GoodsReceiptItem {
  id             String       @id @default(cuid())
  goodsReceiptId String
  goodsReceipt   GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  productId      String
  product        Product      @relation("GRItems", fields: [productId], references: [id])
  quantity       Decimal      @db.Decimal(14, 4)
  unitPrice      Decimal?     @db.Decimal(14, 4)
  unit           UnitOfMeasure @default(UN)
  lotNumber      String?
  expiresAt      DateTime?

  @@map("goods_receipt_items")
}

// ─── Vendas ───────────────────────────────────────────────────────────────────

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  IN_PRODUCTION
  READY
  INVOICED
  DELIVERED
  CANCELLED
}

enum SalesOrderOrigin {
  INTERNAL
  SP_SYSTEM
  NFE
  ECOMMERCE
}

model SalesOrder {
  id              String           @id @default(cuid())
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])
  customerId      String
  customer        Customer         @relation(fields: [customerId], references: [id])
  number          String
  status          SalesOrderStatus @default(DRAFT)
  origin          SalesOrderOrigin @default(INTERNAL)
  deliveryDate    DateTime?
  notes           String?
  totalAmount     Decimal          @default(0) @db.Decimal(14, 2)
  items           SalesOrderItem[]
  serials         SalesOrderSerial[]
  fiscalDocuments FiscalDocument[]
  legacyId        String?
  createdById     String?
  createdBy       User?            @relation("SOCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([companyId, number])
  @@map("sales_orders")
}

model SalesOrderItem {
  id           String        @id @default(cuid())
  salesOrderId String
  salesOrder   SalesOrder    @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product       @relation("SOItems", fields: [productId], references: [id])
  quantity     Decimal       @db.Decimal(14, 4)
  unitPrice    Decimal       @db.Decimal(14, 4)
  totalPrice   Decimal       @db.Decimal(14, 2)
  unit         UnitOfMeasure @default(UN)
  legacyId     String?

  @@map("sales_order_items")
}

model SalesOrderSerial {
  id           String     @id @default(cuid())
  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation("SOSerials", fields: [productId], references: [id])
  serialNumber String
  legacyId     String?

  @@unique([productId, serialNumber])
  @@map("sales_order_serials")
}

// ─── Fiscal / NF-e ────────────────────────────────────────────────────────────

enum FiscalDocumentType {
  NFE
  NFCE
  CTE
  NFSE
}

enum FiscalDocumentDirection {
  OUTBOUND
  INBOUND
}

enum FiscalDocumentStatus {
  DRAFT
  PENDING
  AUTHORIZED
  CANCELLED
  DENIED
  REJECTED
}

model FiscalDocument {
  id                  String                  @id @default(cuid())
  companyId           String
  company             Company                 @relation(fields: [companyId], references: [id])
  salesOrderId        String?
  salesOrder          SalesOrder?             @relation(fields: [salesOrderId], references: [id])
  type                FiscalDocumentType      @default(NFE)
  direction           FiscalDocumentDirection @default(OUTBOUND)
  status              FiscalDocumentStatus    @default(DRAFT)
  accessKey           String?                 @unique // chave de 44 dígitos
  number              String?
  series              String?
  issuedAt            DateTime?
  totalAmount         Decimal?                @db.Decimal(14, 2)
  operationDesc       String?
  recipientTaxId      String?
  recipientName       String?
  issuerTaxId         String?
  issuerName          String?
  xmlContent          String?                 @db.Text
  focusNfeId          String?                 // ID retornado pelo Focus NFe
  legacyId            String?
  items               FiscalDocumentItem[]
  events              FiscalEvent[]
  receivables         Receivable[]
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@map("fiscal_documents")
}

model FiscalDocumentItem {
  id               String         @id @default(cuid())
  fiscalDocumentId String
  fiscalDocument   FiscalDocument @relation(fields: [fiscalDocumentId], references: [id], onDelete: Cascade)
  productId        String?
  product          Product?       @relation("FDItems", fields: [productId], references: [id])
  lineNumber       Int
  description      String
  ncm              String?
  cfop             String?
  quantity         Decimal        @db.Decimal(14, 4)
  unit             String         @default("UN")
  unitPrice        Decimal        @db.Decimal(14, 4)
  totalPrice       Decimal        @db.Decimal(14, 2)
  legacyId         String?
  taxes            FiscalDocumentItemTax[]

  @@map("fiscal_document_items")
}

model FiscalDocumentItemTax {
  id                   String             @id @default(cuid())
  fiscalDocumentItemId String
  fiscalDocumentItem   FiscalDocumentItem @relation(fields: [fiscalDocumentItemId], references: [id], onDelete: Cascade)
  taxType              String             // ICMS | IPI | PIS | COFINS | ISS
  cst                  String?
  baseAmount           Decimal?           @db.Decimal(14, 2)
  rate                 Decimal?           @db.Decimal(7, 4)
  amount               Decimal?           @db.Decimal(14, 2)

  @@map("fiscal_document_item_taxes")
}

enum FiscalEventType {
  CANCELLATION
  CORRECTION
  DENIAL
  OTHER
}

model FiscalEvent {
  id               String          @id @default(cuid())
  fiscalDocumentId String
  fiscalDocument   FiscalDocument  @relation(fields: [fiscalDocumentId], references: [id], onDelete: Cascade)
  type             FiscalEventType
  protocol         String?
  description      String?
  occurredAt       DateTime        @default(now())
  legacyId         String?

  @@map("fiscal_events")
}

// ─── Financeiro ───────────────────────────────────────────────────────────────

enum BankAccountType {
  CHECKING
  SAVINGS
  CASH
  DIGITAL
  INVESTMENT
}

model BankAccount {
  id                String          @id @default(cuid())
  companyId         String
  company           Company         @relation(fields: [companyId], references: [id])
  name              String
  bankCode          String?
  agency            String?
  accountNumber     String?
  type              BankAccountType @default(CHECKING)
  initialBalance    Decimal         @default(0) @db.Decimal(14, 2)
  initialBalanceAt  DateTime?
  isActive          Boolean         @default(true)
  legacyId          String?
  paymentEntries    PaymentEntry[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("bank_accounts")
}

enum FinancialCategoryType {
  REVENUE
  EXPENSE
  TRANSFER
  GROUP
}

model FinancialCategory {
  id          String                @id @default(cuid())
  companyId   String
  company     Company               @relation(fields: [companyId], references: [id])
  code        String
  name        String
  type        FinancialCategoryType
  parentId    String?
  parent      FinancialCategory?    @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    FinancialCategory[]   @relation("CategoryHierarchy")
  dreCode     String?               // código DRE para classificação
  isActive    Boolean               @default(true)
  legacyId    String?
  payables    PayableCategory[]
  receivables Receivable[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([companyId, code])
  @@map("financial_categories")
}

model CostCenter {
  id           String               @id @default(cuid())
  companyId    String
  company      Company              @relation(fields: [companyId], references: [id])
  code         String
  name         String
  isActive     Boolean              @default(true)
  legacyId     String?
  payables     PayableDepartment[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@unique([companyId, code])
  @@map("cost_centers")
}

enum PayableStatus {
  OPEN
  PAID
  PARTIAL
  CANCELLED
  OVERDUE
}

model Payable {
  id              String              @id @default(cuid())
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id])
  supplierId      String?
  supplier        Supplier?           @relation("PayableSupplier", fields: [supplierId], references: [id])
  description     String
  amount          Decimal             @db.Decimal(14, 2)
  dueDate         DateTime
  status          PayableStatus       @default(OPEN)
  paidAt          DateTime?
  paidAmount      Decimal?            @db.Decimal(14, 2)
  barcode         String?
  originRef       String?             // id_origem: APIP, EXTP, BAXP
  legacyId        String?
  categories      PayableCategory[]
  departments     PayableDepartment[]
  entries         PaymentEntry[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@map("payables")
}

model PayableCategory {
  id                  String            @id @default(cuid())
  payableId           String
  payable             Payable           @relation(fields: [payableId], references: [id], onDelete: Cascade)
  financialCategoryId String
  financialCategory   FinancialCategory @relation(fields: [financialCategoryId], references: [id])
  percentage          Decimal           @db.Decimal(5, 2)
  amount              Decimal           @db.Decimal(14, 2)
  legacyId            String?

  @@map("payable_categories")
}

model PayableDepartment {
  id          String     @id @default(cuid())
  payableId   String
  payable     Payable    @relation(fields: [payableId], references: [id], onDelete: Cascade)
  costCenterId String
  costCenter  CostCenter @relation(fields: [costCenterId], references: [id])
  percentage  Decimal    @db.Decimal(5, 2)
  amount      Decimal    @db.Decimal(14, 2)
  legacyId    String?

  @@map("payable_departments")
}

model PaymentEntry {
  id            String       @id @default(cuid())
  companyId     String
  company       Company      @relation(fields: [companyId], references: [id])
  payableId     String?
  payable       Payable?     @relation(fields: [payableId], references: [id])
  receivableId  String?
  receivable    Receivable?  @relation(fields: [receivableId], references: [id])
  bankAccountId String?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id])
  amount        Decimal      @db.Decimal(14, 2)
  paidAt        DateTime
  method        String?      // PIX | TED | BOLETO | CARTAO | DINHEIRO
  legacyId      String?
  createdAt     DateTime     @default(now())

  @@map("payment_entries")
}

enum ReceivableStatus {
  OPEN
  PAID
  PARTIAL
  CANCELLED
  OVERDUE
}

model Receivable {
  id                 String            @id @default(cuid())
  companyId          String
  company            Company           @relation(fields: [companyId], references: [id])
  customerId         String?
  customer           Customer?         @relation("ReceivableCustomer", fields: [customerId], references: [id])
  fiscalDocumentId   String?
  fiscalDocument     FiscalDocument?   @relation(fields: [fiscalDocumentId], references: [id])
  financialCategoryId String?
  financialCategory  FinancialCategory? @relation(fields: [financialCategoryId], references: [id])
  description        String
  amount             Decimal           @db.Decimal(14, 2)
  dueDate            DateTime
  status             ReceivableStatus  @default(OPEN)
  paidAt             DateTime?
  paidAmount         Decimal?          @db.Decimal(14, 2)
  legacyId           String?
  entries            PaymentEntry[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@map("receivables")
}

// ─── Transferência Fábrica → Loja ─────────────────────────────────────────────

enum StockTransferStatus {
  DRAFT
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

model StockTransfer {
  id              String              @id @default(cuid())
  companyId       String
  company         Company             @relation(fields: [companyId], references: [id])
  fromWarehouseId String
  fromWarehouse   Warehouse           @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String
  toWarehouse     Warehouse           @relation("TransferTo", fields: [toWarehouseId], references: [id])
  number          String
  status          StockTransferStatus @default(DRAFT)
  fiscalNfeKey    String?
  notes           String?
  items           StockTransferItem[]
  shippedAt       DateTime?
  receivedAt      DateTime?
  legacyId        String?
  createdById     String?
  createdBy       User?               @relation("TransferCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([companyId, number])
  @@map("stock_transfers")
}

model StockTransferItem {
  id              String        @id @default(cuid())
  stockTransferId String
  stockTransfer   StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation("TransferItems", fields: [productId], references: [id])
  quantity        Decimal       @db.Decimal(14, 4)
  unit            UnitOfMeasure @default(UN)
  serialNumber    String?

  @@map("stock_transfer_items")
}
