// ─── Alertas (S24) ───────────────────────────────────────────────────────────

enum AlertType {
  STOCK_MIN
  PAYABLE_DUE
  PRODUCTION_LATE
  NFE_REJECTED
  MRP_RUN_DONE
  FOCUS_NFE_DOWN
  QC_INSPECTION_FAILED
  MAINTENANCE_DUE
  MANIFEST_OVERDUE
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model Alert {
  id          String        @id @default(cuid())
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id])
  type        AlertType
  severity    AlertSeverity @default(WARNING)
  title       String
  body        String
  entityId    String?
  entityType  String?
